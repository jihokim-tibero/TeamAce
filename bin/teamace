#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────
# TeamAce CLI
# ─────────────────────────────────────────────

VERSION_FILE="$HOME/.claude/teamace/version"
TEAMACE_DIR="$HOME/.claude/teamace"
CLAUDE_DIR="$HOME/.claude"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[TeamAce]${NC} $1"; }
ok()    { echo -e "${GREEN}[TeamAce]${NC} $1"; }
warn()  { echo -e "${YELLOW}[TeamAce]${NC} $1"; }
err()   { echo -e "${RED}[TeamAce]${NC} $1" >&2; }

check_installed() {
  if [ ! -f "$VERSION_FILE" ]; then
    err "TeamAce가 설치되어 있지 않습니다. install.sh를 먼저 실행하세요."
    exit 1
  fi
}

# Git 플랫폼 감지
detect_platform() {
  local dir="$1"
  local origin_url
  origin_url=$(git -C "$dir" config --get remote.origin.url 2>/dev/null)

  # 1. URL 문자열로 판별
  if echo "$origin_url" | grep -q "github.com"; then
    echo "github"; return
  elif echo "$origin_url" | grep -qi "gitlab"; then
    echo "gitlab"; return
  elif echo "$origin_url" | grep -q "bitbucket"; then
    echo "bitbucket"; return
  fi

  # 2. .gitlab-ci.yml 존재
  if [ -f "$dir/.gitlab-ci.yml" ]; then
    echo "gitlab"; return
  fi

  # 3. remote 호스트의 GitLab API 확인 (자체 호스팅 대응)
  local host
  host=$(echo "$origin_url" | sed -E 's#^(https?://|git@)([^/:]+).*#\2#')
  if [ -n "$host" ]; then
    # http(s) 프로토콜 감지
    local scheme="https"
    echo "$origin_url" | grep -q "^http://" && scheme="http"
    if curl -s --max-time 3 -o /dev/null -w "%{http_code}" "${scheme}://${host}/api/v4/version" 2>/dev/null | grep -qE "^(200|401|403)$"; then
      echo "gitlab"; return
    fi
  fi

  echo "unknown"
}

# Agent Team 실험 기능 활성화 여부 확인
check_agent_team() {
  if [ -f "$CLAUDE_DIR/settings.json" ]; then
    node -e "
      const s = JSON.parse(require('fs').readFileSync('$CLAUDE_DIR/settings.json','utf8'));
      process.exit(s.env && s.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS === '1' ? 0 : 1);
    " 2>/dev/null && return 0
  fi
  # 환경변수로도 체크
  [ "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" = "1" ] && return 0
  return 1
}

# Impeccable 설치 여부 확인 (글로벌 + 프로젝트 레벨)
check_impeccable() {
  local project="${1:-.}"
  # 글로벌: ~/.agents/skills/ (npx skills add --global)
  ls "$HOME"/.agents/skills/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$HOME/.agents/skills/frontend-design" ] && return 0
  # 글로벌: ~/.claude/commands/ (Claude Code symlink)
  ls "$HOME"/.claude/commands/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$HOME/.claude/commands/frontend-design" ] && return 0
  # 프로젝트 레벨 (레거시)
  ls "$project"/.claude/skills/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$project/.claude/skills/frontend-design" ] && return 0
  return 1
}

# ─────────────────────────────────────────────
# 버전 조회 + 스택 감지 + 로컬 Toolchain 설치
# ─────────────────────────────────────────────

# Maven Central에서 최신 릴리스 버전 조회 (네트워크 실패 시 기본값)
# $1 = groupPath (e.g. "com/diffplug/spotless/spotless-plugin-gradle")
# $2 = 기본값
fetch_maven_latest() {
  local group_path="$1"
  local fallback="$2"
  local ver
  ver=$(curl -sL --max-time 5 \
    "https://repo1.maven.org/maven2/$group_path/maven-metadata.xml" 2>/dev/null \
    | grep '<release>' | head -1 | sed 's/.*<release>\(.*\)<\/release>.*/\1/')
  echo "${ver:-$fallback}"
}

# 프로젝트 스택 감지
# stdout: "node" | "python" | "java-maven" | "java-gradle" | "unknown"
detect_stack() {
  local dir="$1"
  if [ -f "$dir/package.json" ]; then echo "node"
  elif [ -f "$dir/pyproject.toml" ] || [ -f "$dir/requirements.txt" ] || [ -f "$dir/setup.py" ] || [ -f "$dir/Pipfile" ]; then echo "python"
  elif [ -f "$dir/pom.xml" ]; then echo "java-maven"
  elif [ -f "$dir/build.gradle" ] || [ -f "$dir/build.gradle.kts" ]; then echo "java-gradle"
  else echo "unknown"
  fi
}

# ── Node 스택 로컬 설치 ──
setup_toolchain_node() {
  local dir="$1"
  local need_install=0

  # 1) TypeScript strict
  if [ -f "$dir/tsconfig.json" ]; then
    if node -e "
      const c=require('fs').readFileSync('$dir/tsconfig.json','utf8').replace(/\/\/.*/g,'').replace(/\/\*[\s\S]*?\*\//g,'').replace(/,\s*([}\]])/g,'$1');
      const t=JSON.parse(c);process.exit(t.compilerOptions&&t.compilerOptions.strict===true?0:1);
    " 2>/dev/null; then
      ok "    → TypeScript strict: 이미 활성화됨"
    else
      if node -e "
        const fs=require('fs');
        const c=fs.readFileSync('$dir/tsconfig.json','utf8').replace(/\/\/.*/g,'').replace(/\/\*[\s\S]*?\*\//g,'').replace(/,\s*([}\]])/g,'$1');
        const t=JSON.parse(c);
        if(!t.compilerOptions)t.compilerOptions={};
        t.compilerOptions.strict=true;
        fs.writeFileSync('$dir/tsconfig.json',JSON.stringify(t,null,2)+'\n');
      " 2>/dev/null; then
        ok "    → TypeScript strict: 활성화 완료"
      else
        warn "    → TypeScript strict: 수동 설정 필요 (compilerOptions.strict = true)"
      fi
    fi
  else
    # tsconfig.json이 없으면 생성
    cat > "$dir/tsconfig.json" << 'TSEOF'
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
TSEOF
    ok "    → TypeScript: tsconfig.json 생성 완료 (strict: true)"
    need_install=1
  fi

  # 2) ESLint
  local has_eslint=0
  for f in "$dir"/eslint.config.{js,mjs,cjs,ts} "$dir"/.eslintrc{,.js,.cjs,.json,.yml,.yaml}; do
    [ -f "$f" ] && has_eslint=1 && break
  done
  if [ "$has_eslint" -eq 1 ]; then
    ok "    → ESLint: 설정 이미 존재"
  else
    cat > "$dir/eslint.config.mjs" << 'ESLINTEOF'
import js from "@eslint/js";
import tseslint from "typescript-eslint";
import globals from "globals";

export default [
  { ignores: ["dist/**", "build/**", "node_modules/**"] },
  js.configs.recommended,
  ...tseslint.configs.recommended,
  {
    languageOptions: {
      globals: { ...globals.browser, ...globals.es2021 },
    },
    rules: {
      "no-console": "error",
      "max-lines": ["warn", 300],
      "max-lines-per-function": ["warn", { max: 100 }],
      "@typescript-eslint/no-explicit-any": "error",
      "@typescript-eslint/no-unused-vars": [
        "error",
        { argsIgnorePattern: "^_", varsIgnorePattern: "^_" },
      ],
      camelcase: ["error", { properties: "always" }],
    },
  },
  {
    files: ["vite.config.*", "*.config.{js,ts,mjs,cjs}"],
    languageOptions: {
      globals: { ...globals.node },
    },
  },
];
ESLINTEOF
    ok "    → ESLint: eslint.config.mjs 생성 완료"
    need_install=1
  fi

  # 3) Husky hooks
  mkdir -p "$dir/.husky"
  local husky_changed=0

  if [ ! -f "$dir/.husky/commit-msg" ]; then
    printf 'npx --no -- commitlint --edit "$1"\n' > "$dir/.husky/commit-msg"
    chmod +x "$dir/.husky/commit-msg"
    husky_changed=1
  fi

  if [ ! -f "$dir/.husky/pre-push" ]; then
    cat > "$dir/.husky/pre-push" << 'HOOKEOF'
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo "main 브랜치에 직접 push할 수 없습니다."
  exit 1
fi
HOOKEOF
    chmod +x "$dir/.husky/pre-push"
    husky_changed=1
  fi

  # Config Guard + Lint 실행
  if [ ! -f "$dir/.husky/pre-commit" ]; then
    cat > "$dir/.husky/pre-commit" << 'HOOKEOF'
#!/usr/bin/env bash
# TeamAce pre-commit — Config Guard + Lint + Type Check
failed=0

# ── Config Guard: 핵심 설정 변경 차단 ──
if [ -f tsconfig.json ]; then
  if ! node -e "
    const c=require('fs').readFileSync('tsconfig.json','utf8').replace(/\/\/.*/g,'').replace(/\/\*[\s\S]*?\*\//g,'').replace(/,\s*([}\]])/g,'\$1');
    const t=JSON.parse(c);process.exit(t.compilerOptions&&t.compilerOptions.strict===true?0:1);
  " 2>/dev/null; then
    echo "[Config Guard] tsconfig.json: strict 모드가 비활성화되어 있습니다."
    failed=1
  fi
fi

for cfg in eslint.config.*; do
  [ -f "$cfg" ] || continue
  if ! grep -q "no-console" "$cfg" 2>/dev/null; then
    echo "[Config Guard] ESLint: no-console 규칙이 제거되었습니다."
    failed=1
  fi
  if ! grep -q "no-explicit-any" "$cfg" 2>/dev/null; then
    echo "[Config Guard] ESLint: no-explicit-any 규칙이 제거되었습니다."
    failed=1
  fi
  break
done

[ "$failed" -eq 1 ] && exit 1

# ── ESLint 실행 (워닝도 에러 처리) ──
if command -v npx >/dev/null 2>&1 && [ -f node_modules/.bin/eslint ]; then
  echo "[pre-commit] ESLint 검사 중..."
  npx eslint . --max-warnings 0 || exit 1
fi

# ── TypeScript 타입 체크 ──
if [ -f tsconfig.json ] && [ -f node_modules/.bin/tsc ]; then
  echo "[pre-commit] TypeScript 타입 검사 중..."
  npx tsc --noEmit || exit 1
fi
HOOKEOF
    chmod +x "$dir/.husky/pre-commit"
    husky_changed=1
  fi

  if [ "$husky_changed" -eq 1 ]; then
    ok "    → Husky: 훅 생성 완료 (pre-commit, commit-msg, pre-push)"
    need_install=1
  else
    ok "    → Husky: 이미 설정됨"
  fi

  # 4) commitlint
  local has_commitlint=0
  for f in "$dir"/commitlint.config.{js,cjs,mjs,ts} "$dir"/.commitlintrc{,.js,.cjs,.json,.yml,.yaml}; do
    [ -f "$f" ] && has_commitlint=1 && break
  done
  if [ "$has_commitlint" -eq 1 ]; then
    ok "    → commitlint: 설정 이미 존재"
  else
    echo "export default { extends: ['@commitlint/config-conventional'] };" > "$dir/commitlint.config.mjs"
    ok "    → commitlint: commitlint.config.mjs 생성 완료"
    need_install=1
  fi

  # 5) npm install
  if [ "$need_install" -eq 1 ]; then
    info "    npm 패키지 설치 중..."
    if (cd "$dir" && npm install -D \
      eslint @eslint/js typescript-eslint globals \
      husky @commitlint/cli @commitlint/config-conventional \
      >/dev/null 2>&1); then
      ok "    → 패키지 설치 완료"
      (cd "$dir" && npx husky >/dev/null 2>&1) || true
    else
      warn "    → 패키지 설치 실패 — 수동 실행:"
      echo "      cd $dir && npm install -D eslint @eslint/js typescript-eslint globals husky @commitlint/cli @commitlint/config-conventional"
    fi
  fi
}

# ── Python 스택 로컬 설치 ──
setup_toolchain_python() {
  local dir="$1"
  local need_install=0

  # 1) Ruff 설정
  if [ -f "$dir/ruff.toml" ]; then
    ok "    → Ruff: 설정 이미 존재 (ruff.toml)"
  elif [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.ruff\]" "$dir/pyproject.toml" 2>/dev/null; then
    ok "    → Ruff: 설정 이미 존재 (pyproject.toml)"
  else
    if [ -f "$dir/pyproject.toml" ]; then
      cat >> "$dir/pyproject.toml" << 'RUFFEOF'

[tool.ruff]
line-length = 120
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "A", "C4", "SIM"]

[tool.ruff.format]
quote-style = "double"
RUFFEOF
      ok "    → Ruff: pyproject.toml에 설정 추가"
    else
      cat > "$dir/ruff.toml" << 'RUFFEOF'
line-length = 120
target-version = "py311"

[lint]
select = ["E", "F", "W", "I", "N", "UP", "B", "A", "C4", "SIM"]

[format]
quote-style = "double"
RUFFEOF
      ok "    → Ruff: ruff.toml 생성 완료"
    fi
    need_install=1
  fi

  # 2) mypy 설정
  if [ -f "$dir/mypy.ini" ] || [ -f "$dir/.mypy.ini" ]; then
    ok "    → mypy: 설정 이미 존재"
  elif [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.mypy\]" "$dir/pyproject.toml" 2>/dev/null; then
    ok "    → mypy: 설정 이미 존재 (pyproject.toml)"
  else
    if [ -f "$dir/pyproject.toml" ]; then
      cat >> "$dir/pyproject.toml" << 'MYPYEOF'

[tool.mypy]
strict = true
python_version = "3.11"
warn_return_any = true
warn_unused_configs = true
ignore_missing_imports = true
MYPYEOF
      ok "    → mypy: pyproject.toml에 strict 설정 추가"
    else
      cat > "$dir/mypy.ini" << 'MYPYEOF'
[mypy]
strict = True
python_version = 3.11
warn_return_any = True
warn_unused_configs = True
ignore_missing_imports = True
MYPYEOF
      ok "    → mypy: mypy.ini 생성 완료"
    fi
    need_install=1
  fi

  # 3) 패키지 설치
  if [ "$need_install" -eq 1 ]; then
    info "    패키지 설치 중..."
    local pip_cmd="pip3"
    command -v pip3 >/dev/null 2>&1 || pip_cmd="pip"

    if ($pip_cmd install ruff mypy pre-commit >/dev/null 2>&1); then
      ok "    → pip 패키지 설치 완료 (ruff, mypy, pre-commit)"
    else
      warn "    → pip 설치 실패 — 수동 실행: $pip_cmd install ruff mypy pre-commit"
    fi
  fi

  # NOTE: pre-commit config 생성 및 install은 setup_toolchain에서
  # git 루트 기준으로 한 번만 수행 (모노레포에서 서브모듈별 install 금지)
}

# pre-commit config를 git 루트에 생성 + install + autoupdate
# $1 = git 루트 디렉터리
_setup_precommit_root() {
  local git_root="$1"

  if [ -f "$git_root/.pre-commit-config.yaml" ]; then
    ok "  → pre-commit: 루트 설정 이미 존재"
  else
    cat > "$git_root/.pre-commit-config.yaml" << 'PCEOF'
repos:
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.0.0
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format
  - repo: https://github.com/pre-commit/mirrors-mypy
    rev: v0.0.0
    hooks:
      - id: mypy
  - repo: local
    hooks:
      - id: config-guard
        name: TeamAce Config Guard
        entry: bash
        args:
          - -c
          - |
            failed=0
            for f in $(find . -maxdepth 3 \( -name pyproject.toml -o -name mypy.ini \) ! -path '*/node_modules/*'); do
              if grep -qiE '^\[tool\.mypy\]|^\[mypy\]' "$f" 2>/dev/null; then
                if ! grep -qiE 'strict\s*=\s*(true|True)' "$f" 2>/dev/null; then
                  echo "[Config Guard] $f: mypy strict 비활성"
                  failed=1
                fi
              fi
            done
            exit $failed
        language: system
        always_run: true
        pass_filenames: false
PCEOF
    ok "  → pre-commit: 루트 .pre-commit-config.yaml 생성 완료"
  fi

  # autoupdate
  if command -v pre-commit >/dev/null 2>&1; then
    info "  pre-commit 훅 버전 최신화 중..."
    if (cd "$git_root" && pre-commit autoupdate >/dev/null 2>&1); then
      ok "  → pre-commit autoupdate 완료"
    else
      warn "  → pre-commit autoupdate 실패 (네트워크 확인)"
    fi

    if (cd "$git_root" && pre-commit install >/dev/null 2>&1); then
      ok "  → pre-commit 훅 설치 완료 (루트)"
    else
      warn "  → pre-commit 훅 설치 실패 — 수동 실행: cd $git_root && pre-commit install"
    fi
  fi
}

# ── Java 스택 로컬 설치 ──
setup_toolchain_java() {
  local dir="$1"
  local build_tool="$2"  # "maven" or "gradle"
  local need_setup=0

  # 1) Checkstyle 설정
  if [ -f "$dir/checkstyle.xml" ] || [ -f "$dir/config/checkstyle/checkstyle.xml" ]; then
    ok "    → Checkstyle: 설정 이미 존재"
  else
    mkdir -p "$dir/config/checkstyle"
    cat > "$dir/config/checkstyle/checkstyle.xml" << 'CSEOF'
<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
  <module name="TreeWalker">
    <module name="ConstantName"/>
    <module name="LocalVariableName"/>
    <module name="MemberName"/>
    <module name="MethodName"/>
    <module name="PackageName"/>
    <module name="ParameterName"/>
    <module name="TypeName"/>
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>
    <module name="WhitespaceAround">
      <property name="allowEmptyTypes" value="true"/>
      <property name="allowEmptyConstructors" value="true"/>
      <property name="allowEmptyMethods" value="true"/>
      <property name="allowEmptyLambdas" value="true"/>
    </module>
    <module name="EmptyBlock"/>
    <module name="MissingSwitchDefault"/>
    <module name="FallThrough"/>
    <module name="UpperEll"/>
  </module>
  <module name="FileLength">
    <property name="max" value="700"/>
  </module>
  <module name="NewlineAtEndOfFile"/>
</module>
CSEOF
    ok "    → Checkstyle: config/checkstyle/checkstyle.xml 생성 완료"
    need_setup=1
  fi

  # 2) Git hooks (.githooks/ — 외부 도구 의존 없이 동작)
  local hooks_dir="$dir/.githooks"
  mkdir -p "$hooks_dir"
  local hooks_changed=0

  if [ ! -f "$hooks_dir/commit-msg" ]; then
    cat > "$hooks_dir/commit-msg" << 'HOOKEOF'
#!/usr/bin/env bash
commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,}"
if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "커밋 메시지가 Conventional Commits 형식이 아닙니다."
  echo "형식: <type>(<scope>): <description>"
  echo "예시: feat(auth): 로그인 API 추가"
  exit 1
fi
HOOKEOF
    chmod +x "$hooks_dir/commit-msg"
    hooks_changed=1
  fi

  if [ ! -f "$hooks_dir/pre-push" ]; then
    cat > "$hooks_dir/pre-push" << 'HOOKEOF'
#!/usr/bin/env bash
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo "main 브랜치에 직접 push할 수 없습니다."
  exit 1
fi
HOOKEOF
    chmod +x "$hooks_dir/pre-push"
    hooks_changed=1
  fi

  # Config Guard + Lint 실행
  if [ ! -f "$hooks_dir/pre-commit" ]; then
    cat > "$hooks_dir/pre-commit" << 'HOOKEOF'
#!/usr/bin/env bash
# TeamAce pre-commit — Config Guard + Checkstyle + Spotless

# ── Config Guard ──
if [ ! -f config/checkstyle/checkstyle.xml ] && [ ! -f checkstyle.xml ]; then
  echo "[Config Guard] checkstyle.xml이 삭제되었습니다."
  exit 1
fi

# ── Gradle 프로젝트: checkstyle + spotless 실행 ──
if [ -f gradlew ]; then
  echo "[pre-commit] Checkstyle 검사 중..."
  ./gradlew checkstyleMain --quiet 2>&1 || exit 1

  echo "[pre-commit] Spotless 포맷 검사 중..."
  ./gradlew spotlessCheck --quiet 2>&1 || exit 1
fi

# ── Maven 프로젝트: checkstyle 실행 ──
if [ -f mvnw ] || [ -f pom.xml ]; then
  local mvn_cmd="mvn"
  [ -f mvnw ] && mvn_cmd="./mvnw"
  echo "[pre-commit] Checkstyle 검사 중..."
  $mvn_cmd checkstyle:check -q 2>&1 || exit 1
fi
HOOKEOF
    chmod +x "$hooks_dir/pre-commit"
    hooks_changed=1
  fi

  if [ "$hooks_changed" -eq 1 ]; then
    ok "    → Git hooks: .githooks/ 생성 완료 (pre-commit, commit-msg, pre-push)"
    need_setup=1
  else
    ok "    → Git hooks: 이미 설정됨"
  fi

  # 3) core.hooksPath 설정
  if [ "$need_setup" -eq 1 ]; then
    if (cd "$dir" && git config core.hooksPath .githooks 2>/dev/null); then
      ok "    → git core.hooksPath → .githooks 설정 완료"
    else
      warn "    → git 설정 실패 — 수동 실행: cd $dir && git config core.hooksPath .githooks"
    fi
  fi

  # 4) 빌드 도구 플러그인 안내 (미설정 시에만, 버전은 동적 조회)
  if [ "$build_tool" = "maven" ]; then
    if ! grep -q "checkstyle\|spotless" "$dir/pom.xml" 2>/dev/null; then
      local cs_plugin_ver
      cs_plugin_ver=$(fetch_maven_latest "org/apache/maven/plugins/maven-checkstyle-plugin" "3.6.0")
      echo ""
      info "    [Maven] pom.xml <plugins> 블록에 다음을 추가하세요:"
      echo ""
      echo "      <plugin>"
      echo "        <groupId>org.apache.maven.plugins</groupId>"
      echo "        <artifactId>maven-checkstyle-plugin</artifactId>"
      echo "        <version>${cs_plugin_ver}</version>"
      echo "        <configuration>"
      echo "          <configLocation>config/checkstyle/checkstyle.xml</configLocation>"
      echo "        </configuration>"
      echo "      </plugin>"
      echo ""
    else
      ok "    → Maven 빌드 플러그인: 이미 설정됨"
    fi
  else
    local gf=""
    [ -f "$dir/build.gradle" ] && gf="$dir/build.gradle"
    [ -f "$dir/build.gradle.kts" ] && gf="$dir/build.gradle.kts"
    if [ -n "$gf" ] && grep -q "checkstyle\|spotless" "$gf" 2>/dev/null; then
      ok "    → Gradle 빌드 플러그인: 이미 설정됨"
    else
      local spotless_ver gjf_ver
      spotless_ver=$(fetch_maven_latest "com/diffplug/spotless/spotless-plugin-gradle" "8.4.0")
      gjf_ver=$(fetch_maven_latest "com/google/googlejavaformat/google-java-format" "1.35.0")
      echo ""
      info "    [Gradle] plugins 블록에 다음을 추가하세요:"
      echo ""
      echo "      // plugins 블록에 추가:"
      echo "      id 'checkstyle'"
      echo "      id 'com.diffplug.spotless' version '${spotless_ver}'"
      echo ""
      echo "      // plugins 블록 밖에 추가:"
      echo "      checkstyle {"
      echo "          configFile = file('config/checkstyle/checkstyle.xml')"
      echo "      }"
      echo ""
      echo "      spotless {"
      echo "          java {"
      echo "              googleJavaFormat('${gjf_ver}')"
      echo "          }"
      echo "      }"
      echo ""
    fi
  fi
}

# ── 하위 모듈 탐색 (루트 제외, 최대 깊이 3) ──
# node_modules, .git, build, dist, vendor, target 등 제외
# stdout: 모듈 디렉터리 절대 경로 (한 줄에 하나, 중복 제거)
find_modules() {
  local root="$1"
  find "$root" -maxdepth 3 -mindepth 2 \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/vendor/*' \
    -not -path '*/build/*' \
    -not -path '*/dist/*' \
    -not -path '*/.gradle/*' \
    -not -path '*/target/*' \
    -not -path '*/.claude/*' \
    \( -name 'package.json' \
       -o -name 'pyproject.toml' \
       -o -name 'requirements.txt' \
       -o -name 'setup.py' \
       -o -name 'Pipfile' \
       -o -name 'pom.xml' \
       -o -name 'build.gradle' \
       -o -name 'build.gradle.kts' \
    \) 2>/dev/null | while IFS= read -r f; do
    dirname "$f"
  done | sort -u
}

# 단일 모듈에 스택별 도구 설치 (내부용)
_run_setup() {
  local mod_dir="$1"
  local mod_label="$2"
  local mod_stack
  mod_stack=$(detect_stack "$mod_dir")
  [ "$mod_stack" = "unknown" ] && return 0

  echo ""
  info "─── ${mod_label} (${mod_stack}) ───"

  case "$mod_stack" in
    node)        setup_toolchain_node "$mod_dir" ;;
    python)      setup_toolchain_python "$mod_dir" ;;
    java-maven)  setup_toolchain_java "$mod_dir" "maven" ;;
    java-gradle) setup_toolchain_java "$mod_dir" "gradle" ;;
  esac
}

# ── 디렉터리 Toolchain 설치 (스택 자동 감지 + 하위 모듈 재귀 탐색) ──
setup_toolchain() {
  local dir="$1"
  local label="${2:-}"
  local stack
  stack=$(detect_stack "$dir")

  # 하위 모듈 탐색
  local -a modules=()
  while IFS= read -r mod; do
    [ -n "$mod" ] && modules+=("$mod")
  done < <(find_modules "$dir")

  local has_python=0
  local git_root=""
  # git 루트 찾기
  git_root=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null) || git_root="$dir"

  if [ ${#modules[@]} -gt 0 ]; then
    # 하위 모듈 발견 → 각 모듈별로 설치
    for mod in "${modules[@]}"; do
      local rel="${mod#$dir/}"
      _run_setup "$mod" "$rel"
      [ "$(detect_stack "$mod")" = "python" ] && has_python=1
    done
  elif [ "$stack" != "unknown" ]; then
    # 루트에만 스택 존재
    if [ -n "$label" ]; then
      _run_setup "$dir" "$label"
    else
      info "  스택 감지: ${stack}"
      case "$stack" in
        node)        setup_toolchain_node "$dir" ;;
        python)      setup_toolchain_python "$dir" ;;
        java-maven)  setup_toolchain_java "$dir" "maven" ;;
        java-gradle) setup_toolchain_java "$dir" "gradle" ;;
      esac
    fi
    [ "$stack" = "python" ] && has_python=1
  else
    [ -n "$label" ] && info "  ${label}: 지원 스택 감지 안 됨 (건너뜀)"
    info "  지원 스택 없음 (node/python/java)"
  fi

  # Python 모듈이 있으면 git 루트에 pre-commit config + install (한 번만)
  if [ "$has_python" -eq 1 ]; then
    echo ""
    _setup_precommit_root "$git_root"
  fi
}

# 단일 모듈 상태 표시 (내부용)
_show_module_status() {
  local dir="$1"
  local label="$2"
  local stack
  stack=$(detect_stack "$dir")
  [ "$stack" = "unknown" ] && return 0

  echo -e "  ${BOLD}${label}${NC} (${stack})"

  case "$stack" in
    node)
      local has=0
      for f in "$dir"/eslint.config.{js,mjs,cjs,ts} "$dir"/.eslintrc{,.js,.cjs,.json,.yml,.yaml}; do
        [ -f "$f" ] && has=1 && break
      done
      if [ "$has" -eq 1 ]; then
        local eslint_ver
        eslint_ver=$(node -e "try{console.log(require('$dir/node_modules/eslint/package.json').version)}catch(e){}" 2>/dev/null)
        [ -n "$eslint_ver" ] && echo -e "    ESLint:      ${GREEN}${eslint_ver}${NC}" || echo -e "    ESLint:      ${GREEN}설정됨${NC}"
      else
        echo -e "    ESLint:      ${YELLOW}없음${NC}"
      fi

      if [ -f "$dir/tsconfig.json" ]; then
        if node -e "const c=require('fs').readFileSync('$dir/tsconfig.json','utf8').replace(/\/\/.*/g,'').replace(/\/\*[\s\S]*?\*\//g,'').replace(/,\s*([}\]])/g,'\$1');const t=JSON.parse(c);process.exit(t.compilerOptions&&t.compilerOptions.strict===true?0:1)" 2>/dev/null; then
          echo -e "    TypeScript:  ${GREEN}strict${NC}"
        else
          echo -e "    TypeScript:  ${YELLOW}strict 아님${NC}"
        fi
      else
        echo -e "    TypeScript:  ${YELLOW}tsconfig 없음${NC}"
      fi

      [ -d "$dir/.husky" ] && echo -e "    Husky:       ${GREEN}설정됨${NC}" || echo -e "    Husky:       ${YELLOW}없음${NC}"

      has=0
      for f in "$dir"/commitlint.config.{js,cjs,mjs,ts} "$dir"/.commitlintrc{,.js,.cjs,.json,.yml,.yaml}; do
        [ -f "$f" ] && has=1 && break
      done
      [ "$has" -eq 1 ] && echo -e "    commitlint:  ${GREEN}설정됨${NC}" || echo -e "    commitlint:  ${YELLOW}없음${NC}"

      # 기대 설정 비교
      local diff_count=0
      echo -e "    ${BOLD}── 설정 비교 ──${NC}"

      # tsconfig compilerOptions
      if [ -f "$dir/tsconfig.json" ]; then
        local ts_diffs
        ts_diffs=$(node -e "
          const c=require('fs').readFileSync('$dir/tsconfig.json','utf8').replace(/\/\/.*/g,'').replace(/\/\*[\s\S]*?\*\//g,'').replace(/,\s*([}\]])/g,'\$1');
          const t=JSON.parse(c);const co=t.compilerOptions||{};
          const expect={strict:true,esModuleInterop:true,skipLibCheck:true,forceConsistentCasingInFileNames:true};
          for(const[k,v]of Object.entries(expect)){
            const cur=co[k];
            if(cur!==v)console.log('tsconfig '+k+'|'+JSON.stringify(cur)+'|'+v);
          }
          for(const k of['noImplicitAny','strictNullChecks','strictFunctionTypes','strictBindCallApply','noImplicitThis']){
            if(co[k]===false)console.log('tsconfig '+k+'|false|strict에 의해 true');
          }
        " 2>/dev/null)
        if [ -n "$ts_diffs" ]; then
          while IFS='|' read -r item cur expect; do
            echo -e "      ${RED}${item}${NC}: ${cur:-없음} (기대: ${expect})"
            diff_count=$((diff_count+1))
          done <<< "$ts_diffs"
        fi
      fi

      # ESLint 규칙
      local eslint_cfg=""
      for f in "$dir"/eslint.config.{js,mjs,cjs,ts}; do
        [ -f "$f" ] && eslint_cfg="$f" && break
      done
      if [ -n "$eslint_cfg" ]; then
        local -A eslint_expect=(
          ["no-console"]="error"
          ["no-explicit-any"]="error"
          ["no-unused-vars"]="error"
          ["camelcase"]="error"
          ["max-lines"]="warn"
          ["max-lines-per-function"]="warn"
        )
        for rule in "${!eslint_expect[@]}"; do
          local exp="${eslint_expect[$rule]}"
          if ! grep -q "$rule" "$eslint_cfg" 2>/dev/null; then
            echo -e "      ${RED}eslint ${rule}${NC}: 없음 (기대: ${exp})"
            diff_count=$((diff_count+1))
          elif grep -qE "['\"]${rule}['\"].*['\"]off['\"]|['\"]${rule}['\"].*:\s*0" "$eslint_cfg" 2>/dev/null; then
            echo -e "      ${RED}eslint ${rule}${NC}: off (기대: ${exp})"
            diff_count=$((diff_count+1))
          fi
        done
        # ignores
        if ! grep -q "dist" "$eslint_cfg" 2>/dev/null; then
          echo -e "      ${YELLOW}eslint ignores${NC}: dist/** 없음 (기대: 포함)"
          diff_count=$((diff_count+1))
        fi
        # globals (browser/node 환경)
        if ! grep -q "globals" "$eslint_cfg" 2>/dev/null; then
          echo -e "      ${YELLOW}eslint globals${NC}: 없음 (기대: browser + node 환경 선언)"
          diff_count=$((diff_count+1))
        fi
      fi

      # Husky hooks
      [ ! -f "$dir/.husky/pre-commit" ] && echo -e "      ${YELLOW}.husky/pre-commit${NC}: 없음 (기대: config guard + eslint + tsc)" && diff_count=$((diff_count+1))
      [ ! -f "$dir/.husky/commit-msg" ] && echo -e "      ${YELLOW}.husky/commit-msg${NC}: 없음 (기대: commitlint)" && diff_count=$((diff_count+1))
      [ ! -f "$dir/.husky/pre-push" ] && echo -e "      ${YELLOW}.husky/pre-push${NC}: 없음 (기대: main 차단)" && diff_count=$((diff_count+1))

      if [ "$diff_count" -eq 0 ]; then echo -e "      ${GREEN}모든 항목 일치${NC}"; fi
      ;;

    python)
      local has_ruff=0
      [ -f "$dir/ruff.toml" ] && has_ruff=1
      [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.ruff\]" "$dir/pyproject.toml" 2>/dev/null && has_ruff=1
      if [ "$has_ruff" -eq 1 ]; then
        local ruff_ver
        ruff_ver=$(ruff --version 2>/dev/null | awk '{print $2}')
        [ -n "$ruff_ver" ] && echo -e "    Ruff:        ${GREEN}${ruff_ver}${NC}" || echo -e "    Ruff:        ${GREEN}설정됨${NC}"
      else
        echo -e "    Ruff:        ${YELLOW}없음${NC}"
      fi

      local has_mypy=0
      { [ -f "$dir/mypy.ini" ] || [ -f "$dir/.mypy.ini" ]; } && has_mypy=1
      [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.mypy\]" "$dir/pyproject.toml" 2>/dev/null && has_mypy=1
      if [ "$has_mypy" -eq 1 ]; then
        local mypy_ver
        mypy_ver=$(mypy --version 2>/dev/null | awk '{print $2}')
        [ -n "$mypy_ver" ] && echo -e "    mypy:        ${GREEN}${mypy_ver}${NC}" || echo -e "    mypy:        ${GREEN}설정됨${NC}"
      else
        echo -e "    mypy:        ${YELLOW}없음${NC}"
      fi

      # pre-commit config는 모듈 또는 git 루트에서 찾기
      local pc_cfg=""
      [ -f "$dir/.pre-commit-config.yaml" ] && pc_cfg="$dir/.pre-commit-config.yaml"
      if [ -z "$pc_cfg" ]; then
        local _gr
        _gr=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null) || true
        [ -n "$_gr" ] && [ -f "$_gr/.pre-commit-config.yaml" ] && pc_cfg="$_gr/.pre-commit-config.yaml"
      fi
      if [ -n "$pc_cfg" ]; then
        local pc_revs
        pc_revs=$(grep "rev:" "$pc_cfg" 2>/dev/null | awk '{print $2}' | tr '\n' ' ' || true)
        echo -e "    pre-commit:  ${GREEN}설정됨${NC} (${pc_revs})"
      else
        echo -e "    pre-commit:  ${YELLOW}없음${NC}"
      fi

      # 기대 설정 비교
      local diff_count=0
      echo -e "    ${BOLD}── 설정 비교 ──${NC}"

      # ruff 설정
      local ruff_cfg=""
      [ -f "$dir/ruff.toml" ] && ruff_cfg="$dir/ruff.toml"
      [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.ruff" "$dir/pyproject.toml" 2>/dev/null && ruff_cfg="$dir/pyproject.toml"
      if [ -n "$ruff_cfg" ]; then
        # line-length
        if ! grep -qE "line-length\s*=\s*120" "$ruff_cfg" 2>/dev/null; then
          local cur_ll
          cur_ll=$(grep -oP "line-length\s*=\s*\K[0-9]+" "$ruff_cfg" 2>/dev/null | head -1 || true)
          echo -e "      ${YELLOW}ruff line-length${NC}: ${cur_ll:-없음} (기대: 120)"
          diff_count=$((diff_count+1))
        fi
        # select 규칙
        for code in E F W I N UP B A C4 SIM; do
          if ! grep -qE "select\s*=.*\"${code}\"" "$ruff_cfg" 2>/dev/null; then
            echo -e "      ${YELLOW}ruff select ${code}${NC}: 없음 (기대: 포함)"
            diff_count=$((diff_count+1))
          fi
        done
        # ignore에 select 규칙 포함
        for code in E F W I N UP B A C4 SIM; do
          if grep -qE "ignore\s*=.*\"${code}" "$ruff_cfg" 2>/dev/null; then
            echo -e "      ${RED}ruff ignore ${code}${NC}: 포함됨 (기대: 미포함 — select와 충돌)"
            diff_count=$((diff_count+1))
          fi
        done
      fi

      # mypy 설정
      local mypy_cfg=""
      [ -f "$dir/pyproject.toml" ] && grep -q "\[tool\.mypy\]" "$dir/pyproject.toml" 2>/dev/null && mypy_cfg="$dir/pyproject.toml"
      [ -f "$dir/mypy.ini" ] && mypy_cfg="$dir/mypy.ini"
      [ -f "$dir/.mypy.ini" ] && mypy_cfg="$dir/.mypy.ini"
      if [ -n "$mypy_cfg" ]; then
        local -A mypy_expect=(
          ["strict"]="true"
          ["warn_return_any"]="true"
          ["warn_unused_configs"]="true"
          ["ignore_missing_imports"]="true"
        )
        for opt in "${!mypy_expect[@]}"; do
          local exp="${mypy_expect[$opt]}"
          if ! grep -qiE "${opt}\s*=\s*${exp}" "$mypy_cfg" 2>/dev/null; then
            local cur_val
            cur_val=$(grep -oiP "${opt}\s*=\s*\K\S+" "$mypy_cfg" 2>/dev/null | head -1 || true)
            echo -e "      ${RED}mypy ${opt}${NC}: ${cur_val:-없음} (기대: ${exp})"
            diff_count=$((diff_count+1))
          fi
        done
        # strict 하위 옵션이 글로벌 [tool.mypy] 섹션에서 명시적 false
        # (per-module [[tool.mypy.overrides]] 안의 예외는 정당하므로 제외)
        for opt in disallow_untyped_defs disallow_untyped_calls disallow_incomplete_defs; do
          local in_global=0
          if [ "${mypy_cfg##*.}" = "ini" ]; then
            # .ini: [mypy] 섹션과 [mypy-*] 오버라이드 구분
            # [mypy] 직후 ~ 다음 [ 사이에서만 검색
            if sed -n '/^\[mypy\]$/,/^\[/p' "$mypy_cfg" 2>/dev/null | grep -qiE "${opt}\s*=\s*(false|False)"; then
              in_global=1
            fi
          else
            # pyproject.toml: [tool.mypy] 섹션과 [[tool.mypy.overrides]] 구분
            if sed -n '/^\[tool\.mypy\]$/,/^\[/p' "$mypy_cfg" 2>/dev/null | grep -qiE "${opt}\s*=\s*(false|False)"; then
              in_global=1
            fi
          fi
          if [ "$in_global" -eq 1 ]; then
            echo -e "      ${RED}mypy ${opt}${NC}: false (기대: strict에 의해 true)"
            diff_count=$((diff_count+1))
          fi
        done
      fi

      # pre-commit config
      # pre-commit config는 모듈 또는 git 루트에서 찾기
      if [ -z "$pc_cfg" ]; then
        echo -e "      ${YELLOW}.pre-commit-config.yaml${NC}: 없음 (기대: 루트 또는 모듈에 있음)"
        diff_count=$((diff_count+1))
      fi
      if [ "$diff_count" -eq 0 ]; then echo -e "      ${GREEN}모든 항목 일치${NC}"; fi
      ;;

    java-maven|java-gradle)
      local has_cs=0
      { [ -f "$dir/checkstyle.xml" ] || [ -f "$dir/config/checkstyle/checkstyle.xml" ]; } && has_cs=1
      [ "$has_cs" -eq 1 ] && echo -e "    Checkstyle:  ${GREEN}설정됨${NC}" || echo -e "    Checkstyle:  ${YELLOW}없음${NC}"

      # 빌드 플러그인 (checkstyle/spotless) + 버전 표시
      local build_file=""
      [ -f "$dir/pom.xml" ] && build_file="$dir/pom.xml"
      [ -f "$dir/build.gradle" ] && build_file="$dir/build.gradle"
      [ -f "$dir/build.gradle.kts" ] && build_file="$dir/build.gradle.kts"
      if [ -n "$build_file" ] && grep -q "checkstyle\|spotless" "$build_file" 2>/dev/null; then
        local spotless_cur gjf_cur
        spotless_cur=$(grep -oP "spotless.*?version\s*['\"]?\K[0-9][0-9.]*" "$build_file" 2>/dev/null | head -1 || true)
        gjf_cur=$(grep -oP "googleJavaFormat\(['\"]?\K[0-9][0-9.]*" "$build_file" 2>/dev/null | head -1 || true)
        local detail=""
        [ -n "$spotless_cur" ] && detail="spotless ${spotless_cur}"
        [ -n "$gjf_cur" ] && detail="${detail:+$detail, }gjf ${gjf_cur}"
        [ -n "$detail" ] && echo -e "    빌드 플러그인: ${GREEN}설정됨${NC} (${detail})" || echo -e "    빌드 플러그인: ${GREEN}설정됨${NC}"
      else
        echo -e "    빌드 플러그인: ${YELLOW}없음${NC}"
      fi

      [ -d "$dir/.githooks" ] && echo -e "    Git hooks:   ${GREEN}설정됨${NC}" || echo -e "    Git hooks:   ${YELLOW}없음${NC}"

      # 기대 설정 비교
      local diff_count=0
      echo -e "    ${BOLD}── 설정 비교 ──${NC}"

      # checkstyle 모듈
      if [ "$has_cs" -eq 1 ]; then
        local cs_file=""
        [ -f "$dir/config/checkstyle/checkstyle.xml" ] && cs_file="$dir/config/checkstyle/checkstyle.xml"
        [ -f "$dir/checkstyle.xml" ] && cs_file="$dir/checkstyle.xml"
        if [ -n "$cs_file" ]; then
          for mod in ConstantName LocalVariableName MemberName MethodName PackageName ParameterName TypeName AvoidStarImport UnusedImports NeedBraces LeftCurly RightCurly WhitespaceAround EmptyBlock MissingSwitchDefault FallThrough UpperEll NewlineAtEndOfFile; do
            if ! grep -q "$mod" "$cs_file" 2>/dev/null; then
              echo -e "      ${RED}checkstyle ${mod}${NC}: 없음 (기대: 있음)"
              diff_count=$((diff_count+1))
            fi
          done
          # FileLength max 값 비교
          if grep -q "FileLength" "$cs_file" 2>/dev/null; then
            local cur_fl
            cur_fl=$(grep -A2 "FileLength" "$cs_file" 2>/dev/null | grep -oP 'value\s*=\s*"\K[0-9]+' || true)
            if [ -n "$cur_fl" ] && [ "$cur_fl" != "700" ]; then
              echo -e "      ${YELLOW}checkstyle FileLength max${NC}: ${cur_fl} (기대: 700)"
              diff_count=$((diff_count+1))
            fi
          else
            echo -e "      ${RED}checkstyle FileLength${NC}: 없음 (기대: max=700)"
            diff_count=$((diff_count+1))
          fi
          # WhitespaceAround allowEmpty 옵션
          if grep -q "WhitespaceAround" "$cs_file" 2>/dev/null; then
            for prop in allowEmptyTypes allowEmptyConstructors allowEmptyMethods allowEmptyLambdas; do
              if ! grep -q "$prop" "$cs_file" 2>/dev/null; then
                echo -e "      ${YELLOW}checkstyle WhitespaceAround ${prop}${NC}: 없음 (기대: true)"
                diff_count=$((diff_count+1))
              fi
            done
          fi
        fi
      else
        echo -e "      ${RED}checkstyle.xml${NC}: 없음 (기대: 있음)"
        diff_count=$((diff_count+1))
      fi

      # 빌드 플러그인 존재 여부
      if [ -n "$build_file" ]; then
        if ! grep -q "checkstyle" "$build_file" 2>/dev/null; then
          echo -e "      ${RED}빌드 플러그인 checkstyle${NC}: 없음 (기대: 있음 — 빌드 시 스타일 검사)"
          diff_count=$((diff_count+1))
        fi
        if ! grep -q "spotless" "$build_file" 2>/dev/null; then
          echo -e "      ${RED}빌드 플러그인 spotless${NC}: 없음 (기대: 있음 — 빌드 시 포맷 검사)"
          diff_count=$((diff_count+1))
        fi
      fi

      # 빌드 설정 — ignoreFailures / enforceCheck 감지
      if [ -n "$build_file" ]; then
        if grep -qiE "ignoreFailures\s*=\s*true" "$build_file" 2>/dev/null; then
          echo -e "      ${RED}checkstyle ignoreFailures${NC}: true (기대: 제거 — 위반 시 빌드 실패)"
          diff_count=$((diff_count+1))
        fi
        if grep -qiE "enforceCheck\s*=\s*false" "$build_file" 2>/dev/null; then
          echo -e "      ${RED}spotless enforceCheck${NC}: false (기대: 제거 — 빌드 시 포맷 검사)"
          diff_count=$((diff_count+1))
        fi
        if grep -qiE "failOnViolation.*false" "$build_file" 2>/dev/null; then
          echo -e "      ${RED}checkstyle failOnViolation${NC}: false (기대: 제거 — 위반 시 빌드 실패)"
          diff_count=$((diff_count+1))
        fi
      fi

      # Git hooks
      [ ! -d "$dir/.githooks" ] && echo -e "      ${RED}.githooks/${NC}: 없음 (기대: 있음)" && diff_count=$((diff_count+1))
      [ -d "$dir/.githooks" ] && [ ! -f "$dir/.githooks/pre-commit" ] && echo -e "      ${YELLOW}.githooks/pre-commit${NC}: 없음 (기대: config guard + checkstyle + spotless)" && diff_count=$((diff_count+1))
      [ -d "$dir/.githooks" ] && [ ! -f "$dir/.githooks/commit-msg" ] && echo -e "      ${YELLOW}.githooks/commit-msg${NC}: 없음 (기대: conventional commits)" && diff_count=$((diff_count+1))
      [ -d "$dir/.githooks" ] && [ ! -f "$dir/.githooks/pre-push" ] && echo -e "      ${YELLOW}.githooks/pre-push${NC}: 없음 (기대: main 차단)" && diff_count=$((diff_count+1))

      if [ "$diff_count" -eq 0 ]; then echo -e "      ${GREEN}모든 항목 일치${NC}"; fi
      ;;
  esac
}

# ── Toolchain 상태 표시 (하위 모듈 재귀 탐색) ──
show_toolchain_status() {
  local dir="$1"
  local label="${2:-}"
  local stack
  stack=$(detect_stack "$dir")

  # 하위 모듈 탐색
  local -a modules=()
  while IFS= read -r mod; do
    [ -n "$mod" ] && modules+=("$mod")
  done < <(find_modules "$dir")

  if [ ${#modules[@]} -gt 0 ]; then
    for mod in "${modules[@]}"; do
      local rel="${mod#$dir/}"
      _show_module_status "$mod" "$rel"
    done
  elif [ "$stack" != "unknown" ]; then
    local lbl="${label:-$(basename "$dir")}"
    _show_module_status "$dir" "$lbl"
  else
    if [ -n "$label" ]; then
      info "  ${label}: 지원 스택 없음"
    else
      info "  지원 스택 없음 (node/python/java)"
    fi
  fi
  return 0
}

# ─────────────────────────────────────────────
# teamace init — 현재 프로젝트 초기화
# ─────────────────────────────────────────────

cmd_init() {
  check_installed

  local project_dir="${1:-.}"
  project_dir="$(cd "$project_dir" && pwd)"

  info "프로젝트 초기화: $project_dir"
  echo ""

  # Detect project structure: single repo / multi-repo / no repo
  local project_type="none"
  local -a sub_repos=()
  local platforms=""

  if [ -d "$project_dir/.git" ]; then
    project_type="single"
    platforms=$(detect_platform "$project_dir")
    info "Git 저장소: 단일 레포"
    info "Git 플랫폼: $platforms"
  else
    # Scan for git repos in immediate subdirectories
    for d in "$project_dir"/*/; do
      [ -d "${d}.git" ] && sub_repos+=("$(basename "$d")")
    done

    if [ ${#sub_repos[@]} -gt 0 ]; then
      project_type="multi"
      info "멀티 레포 프로젝트 감지 (${#sub_repos[@]}개 레포)"
      for repo in "${sub_repos[@]}"; do
        local p
        p=$(detect_platform "$project_dir/$repo")
        echo -e "    ${CYAN}→${NC} $repo ${BOLD}($p)${NC}"
        # Collect unique platforms
        case "$platforms" in
          *"$p"*) ;;
          "") platforms="$p" ;;
          *)  platforms="$platforms, $p" ;;
        esac
      done
      info "Git 플랫폼: $platforms"
    else
      warn "Git 저장소가 아니며 하위 레포도 없습니다."
      read -rp "그래도 계속 진행하시겠습니까? [y/N] " yn
      [[ "$yn" =~ ^[Yy]$ ]] || exit 0
      platforms="unknown"
      info "Git 플랫폼: $platforms"
    fi
  fi

  # 1. Check Impeccable design skill (글로벌 설치 여부만 확인)
  info "Impeccable 디자인 스킬 확인 중..."
  if check_impeccable "$project_dir"; then
    ok "  → Impeccable 설치됨"
  else
    warn "  → Impeccable이 설치되어 있지 않습니다."
    warn "  → install.sh를 다시 실행하거나 수동으로 설치하세요:"
    warn "    npx skills add pbakaus/impeccable --agent claude-code --global --yes"
  fi

  # 2. Check Agent Team experimental feature
  info "Agent Team 실험 기능 확인 중..."
  if check_agent_team; then
    ok "  → Agent Team 활성화됨"
  else
    warn "  → Agent Team이 비활성 상태입니다."
    warn "  → install.sh를 다시 실행하거나, ~/.claude/settings.json에 다음을 추가하세요:"
    echo '    "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }'
  fi

  # 3. Create project-level knowledge directory
  info "프로젝트 Knowledge 디렉터리 생성 중..."
  local knowledge_dir="$project_dir/.claude/teamace/knowledge"
  mkdir -p "$knowledge_dir"

  for agent in pm pub fe be qa; do
    if [ ! -f "$knowledge_dir/$agent.md" ]; then
      {
        echo "# ${agent^^} Agent — Knowledge Base"
        echo ""
        echo "## 재사용 가능한 패턴"
        echo ""
        echo "## 실수와 회피 방법"
        echo ""
        echo "## 사용자 선호"
        echo ""
      } > "$knowledge_dir/$agent.md"
    fi
  done
  ok "  → .claude/teamace/knowledge/ 생성 완료 (에이전트 5개)"

  # 4. Toolchain 로컬 설치 (스택별 lint, hooks, commit 규칙)
  info "코드 품질 도구 설치 중..."
  echo ""

  if [ "$project_type" = "multi" ]; then
    for repo in "${sub_repos[@]}"; do
      setup_toolchain "$project_dir/$repo" "$repo"
    done
  else
    setup_toolchain "$project_dir"
  fi

  # 5. Create project-level CLAUDE.md if not exists
  local project_claude="$project_dir/CLAUDE.md"
  if [ ! -f "$project_claude" ]; then
    info "프로젝트 CLAUDE.md 생성 중..."

    {
      echo "# 프로젝트 설정"
      echo ""
      echo "- **프로젝트명**: (기입)"
      echo "- **기술 스택**: (기입)"

      if [ "$project_type" = "multi" ]; then
        echo ""
        echo "## 레포지토리 구성"
        echo ""
        for repo in "${sub_repos[@]}"; do
          local p
          p=$(detect_platform "$project_dir/$repo")
          echo "- **$repo** ($p): (역할 기입)"
        done
      fi

      echo ""
      echo "## 프로젝트별 규칙"
      echo ""
      echo "### 린트·정적분석 설정 변경 금지"
      echo ""
      echo "ESLint, tsconfig, Checkstyle, Ruff, mypy 등의 규칙·옵션을 에이전트가 임의로 추가·제거·완화하지 않는다."
      echo ""
      echo "- 린트 에러 발생 시 **코드를 규칙에 맞게 수정**한다 (규칙을 끄지 않는다)"
      echo "- 규칙 자체의 조정이 필요하다고 판단되면 사용자에게 보고하고 승인을 받은 후에만 변경한다"
      echo '- `// eslint-disable`, `# type: ignore`, `@SuppressWarnings` 등 인라인 억제도 동일 — 사유를 명시하고 사용자 승인 필수'
      echo ""
    } > "$project_claude"

    ok "  → CLAUDE.md 생성 완료"
  else
    ok "  → CLAUDE.md 이미 존재 (건너뜀)"
  fi

  # 6. Summary
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN} 프로젝트 초기화 완료!${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo "  프로젝트: $project_dir"
  echo "  구조:     $([ "$project_type" = "multi" ] && echo "멀티 레포 (${#sub_repos[@]}개)" || echo "단일 레포")"
  echo "  플랫폼:   $platforms"
  if [ "$project_type" = "multi" ]; then
    echo "  레포:"
    for repo in "${sub_repos[@]}"; do
      echo "    → $repo"
    done
  fi
  echo ""
  echo "  이제 이 디렉터리에서 Claude Code를 실행하면 TeamAce를 사용할 수 있습니다."
  echo ""
}

# ─────────────────────────────────────────────
# teamace status — 설치 상태 확인
# ─────────────────────────────────────────────

cmd_status() {
  echo ""
  echo -e "${BOLD}TeamAce 설치 상태${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Version
  if [ -f "$VERSION_FILE" ]; then
    echo -e "  버전:          ${GREEN}$(cat "$VERSION_FILE")${NC}"
  else
    echo -e "  버전:          ${RED}미설치${NC}"
    return
  fi

  # Agents
  local agent_count
  agent_count=$(ls "$CLAUDE_DIR"/agents/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  에이전트:      ${GREEN}${agent_count}개${NC} (~/.claude/agents/)"

  # Skills
  local skill_count
  skill_count=$(find "$TEAMACE_DIR/skills" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  스킬:          ${GREEN}${skill_count}개${NC}"

  # Contracts
  local contract_count
  contract_count=$(ls "$TEAMACE_DIR"/contracts/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  계약:          ${GREEN}${contract_count}개${NC}"

  # CLAUDE.md
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -q "TEAMACE:START" "$CLAUDE_DIR/CLAUDE.md"; then
    echo -e "  글로벌 지침:   ${GREEN}적용됨${NC}"
  else
    echo -e "  글로벌 지침:   ${RED}미적용${NC}"
  fi

  # Agent Team
  if check_agent_team; then
    echo -e "  Agent Team:    ${GREEN}활성화${NC}"
  else
    echo -e "  Agent Team:    ${RED}비활성${NC} (install.sh 재실행 필요)"
  fi

  # Current project check
  echo ""
  echo -e "${BOLD}현재 프로젝트 ($(pwd))${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if [ -f "CLAUDE.md" ]; then
    echo -e "  CLAUDE.md:     ${GREEN}있음${NC}"
  else
    echo -e "  CLAUDE.md:     ${YELLOW}없음 (teamace init 실행 필요)${NC}"
  fi

  # Knowledge
  local knowledge_count=0
  if [ -d ".claude/teamace/knowledge" ]; then
    knowledge_count=$(ls .claude/teamace/knowledge/*.md 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  Knowledge:     ${GREEN}${knowledge_count}개${NC} (.claude/teamace/knowledge/)"
  else
    echo -e "  Knowledge:     ${YELLOW}없음 (teamace init 실행 필요)${NC}"
  fi

  if check_impeccable "$(pwd)"; then
    echo -e "  Impeccable:    ${GREEN}설치됨${NC}"
  else
    echo -e "  Impeccable:    ${YELLOW}미설치${NC}"
  fi

  # Detect project structure
  if [ -d ".git" ]; then
    local platform
    platform=$(detect_platform "$(pwd)")
    echo -e "  프로젝트 구조: 단일 레포"
    echo -e "  Git 플랫폼:    ${CYAN}${platform}${NC}"
  else
    local -a status_repos=()
    for d in ./*/; do
      [ -d "${d}.git" ] && status_repos+=("$(basename "$d")")
    done
    if [ ${#status_repos[@]} -gt 0 ]; then
      echo -e "  프로젝트 구조: ${CYAN}멀티 레포 (${#status_repos[@]}개)${NC}"
      for repo in "${status_repos[@]}"; do
        local p
        p=$(detect_platform "$(pwd)/$repo")
        echo -e "    ${CYAN}→${NC} $repo ($p)"
      done
    else
      echo -e "  프로젝트 구조: ${YELLOW}Git 저장소 없음${NC}"
    fi
  fi

  # Toolchain 상태
  echo ""
  echo -e "${BOLD}코드 품질 도구${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  local current_dir
  current_dir="$(pwd)"

  if [ -d ".git" ]; then
    show_toolchain_status "$current_dir"
  else
    local -a tc_repos=()
    for d in ./*/; do
      [ -d "$d" ] && [ "$(detect_stack "$(cd "$d" && pwd)")" != "unknown" ] && tc_repos+=("$(basename "$d")")
    done
    if [ ${#tc_repos[@]} -gt 0 ]; then
      for repo in "${tc_repos[@]}"; do
        show_toolchain_status "$current_dir/$repo" "$repo"
      done
    else
      info "  지원 스택 없음 (node/python/java)"
    fi
  fi
  echo ""
}

# ─────────────────────────────────────────────
# teamace clean — 현재 프로젝트의 init 결과 정리
# ─────────────────────────────────────────────

cmd_clean() {
  local project_dir="${1:-.}"
  project_dir="$(cd "$project_dir" && pwd)"

  info "프로젝트 정리: $project_dir"
  echo ""

  local cleaned=0

  # 1. Remove project CLAUDE.md
  local project_claude="$project_dir/CLAUDE.md"
  if [ -f "$project_claude" ]; then
    warn "CLAUDE.md를 제거합니다."
    read -rp "CLAUDE.md를 삭제하시겠습니까? [y/N] " yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      rm -f "$project_claude"
      ok "  → CLAUDE.md 삭제 완료"
      cleaned=$((cleaned + 1))
    fi
  else
    info "  → CLAUDE.md 없음 (건너뜀)"
  fi

  # 2. Remove project-level knowledge
  if [ -d "$project_dir/.claude/teamace" ]; then
    warn "프로젝트 Knowledge (.claude/teamace/) 를 제거합니다."
    warn "  ⚠ 축적된 학습 기록이 삭제됩니다!"
    read -rp "제거하시겠습니까? [y/N] " yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      rm -rf "$project_dir/.claude/teamace"
      ok "  → .claude/teamace/ 제거 완료"
      cleaned=$((cleaned + 1))
    fi
  fi

  # 3. Remove Impeccable skills from project (레거시 프로젝트 레벨)
  if [ -d "$project_dir/.claude/skills" ]; then
    local has_impeccable=0
    [ -d "$project_dir/.claude/skills/frontend-design" ] && has_impeccable=1
    ls "$project_dir"/.claude/skills/*impeccable* &>/dev/null 2>&1 && has_impeccable=1

    if [ "$has_impeccable" -eq 1 ]; then
      warn "프로젝트 레벨 Impeccable 스킬을 제거합니다. (글로벌로 이관됨)"
      read -rp "제거하시겠습니까? [y/N] " yn
      if [[ "$yn" =~ ^[Yy]$ ]]; then
        rm -rf "$project_dir/.claude/skills"
        ok "  → .claude/skills/ 제거 완료"
        cleaned=$((cleaned + 1))
      fi
    fi
  fi

  # 4. Remove .claude directory if empty
  if [ -d "$project_dir/.claude" ]; then
    if [ -z "$(ls -A "$project_dir/.claude" 2>/dev/null)" ]; then
      rmdir "$project_dir/.claude"
      ok "  → 빈 .claude/ 디렉터리 제거 완료"
    fi
  fi

  echo ""
  if [ "$cleaned" -gt 0 ]; then
    ok "프로젝트 정리 완료 ($cleaned개 항목 제거)"
  else
    info "정리할 항목이 없습니다."
  fi
  echo ""
}

# ─────────────────────────────────────────────
# teamace update — TeamAce 업데이트
# ─────────────────────────────────────────────

cmd_update() {
  check_installed

  local current_version
  current_version=$(cat "$VERSION_FILE")
  info "현재 버전: $current_version"
  info "TeamAce 리포지토리에서 최신 버전을 pull한 후 install.sh를 다시 실행하세요."
  echo ""
  echo "  cd <TeamAce-repo-directory>"
  echo "  git pull"
  echo "  ./install.sh"
  echo ""
}

# ─────────────────────────────────────────────
# teamace uninstall — TeamAce 제거
# ─────────────────────────────────────────────

cmd_uninstall() {
  check_installed

  warn "TeamAce를 완전히 제거합니다."
  read -rp "정말 제거하시겠습니까? [y/N] " yn
  [[ "$yn" =~ ^[Yy]$ ]] || exit 0

  # Remove agents
  for agent in lead pm pub fe be qa; do
    rm -f "$CLAUDE_DIR/agents/$agent.md"
  done
  info "에이전트 정의 제거 완료"

  # Remove teamace directory
  rm -rf "$TEAMACE_DIR"
  info "TeamAce 지원 파일 제거 완료"

  # Remove CLAUDE.md section
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ]; then
    sed '/<!-- TEAMACE:START -->/,/<!-- TEAMACE:END -->/d' "$CLAUDE_DIR/CLAUDE.md" > "$CLAUDE_DIR/CLAUDE.md.tmp"
    mv "$CLAUDE_DIR/CLAUDE.md.tmp" "$CLAUDE_DIR/CLAUDE.md"
    # Remove file if empty
    if [ ! -s "$CLAUDE_DIR/CLAUDE.md" ]; then
      rm -f "$CLAUDE_DIR/CLAUDE.md"
    fi
    info "CLAUDE.md에서 TeamAce 지침 제거 완료"
  fi

  # Remove Agent Team env from settings.json
  if [ -f "$CLAUDE_DIR/settings.json" ]; then
    node -e "
      const fs = require('fs');
      const s = JSON.parse(fs.readFileSync('$CLAUDE_DIR/settings.json', 'utf8'));
      if (s.env) {
        delete s.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS;
        if (Object.keys(s.env).length === 0) delete s.env;
      }
      fs.writeFileSync('$CLAUDE_DIR/settings.json', JSON.stringify(s, null, 2));
    " 2>/dev/null
    info "settings.json에서 Agent Team 설정 제거 완료"
  fi

  # Remove Impeccable global skill
  local impeccable_removed=0
  [ -d "$HOME/.agents/skills/frontend-design" ] && rm -rf "$HOME/.agents/skills/frontend-design" && impeccable_removed=1
  [ -d "$HOME/.claude/commands/frontend-design" ] && rm -rf "$HOME/.claude/commands/frontend-design" && impeccable_removed=1
  for f in "$HOME"/.claude/commands/*impeccable*; do
    [ -e "$f" ] && rm -rf "$f" && impeccable_removed=1
  done
  if [ "$impeccable_removed" -eq 1 ]; then
    info "Impeccable 글로벌 스킬 제거 완료"
  else
    info "Impeccable 글로벌 스킬 없음 (건너뜀)"
  fi

  # Remove CLI
  rm -f "$HOME/.local/bin/teamace"
  info "CLI 제거 완료"

  echo ""
  ok "TeamAce가 완전히 제거되었습니다."
  echo ""
  echo "  참고: 각 프로젝트의 CLAUDE.md에서 TeamAce 참조는 수동으로 제거해주세요."
  echo "        → 'teamace clean' 을 각 프로젝트에서 실행하면 자동 정리됩니다."
  echo ""
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

case "${1:-help}" in
  init)       cmd_init "${2:-}" ;;
  clean)      cmd_clean "${2:-}" ;;
  status)     cmd_status ;;
  update)     cmd_update ;;
  uninstall)  cmd_uninstall ;;
  -v|version) [ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "미설치" ;;
  help|*)
    echo ""
    echo -e "${BOLD}TeamAce${NC} — Multi-Agent Service Development System"
    echo ""
    echo "사용법:"
    echo "  teamace init [path]   현재 프로젝트(또는 지정 경로)에 TeamAce 초기화"
    echo "  teamace clean [path]  현재 프로젝트의 init 결과 정리 (CLAUDE.md, knowledge)"
    echo "  teamace status        설치 상태 및 현재 프로젝트 상태 확인"
    echo "  teamace update        업데이트 안내"
    echo "  teamace uninstall     TeamAce 글로벌 제거 (uninstall.sh와 동일)"
    echo "  teamace version       설치된 버전 출력"
    echo "  teamace help          이 도움말 표시"
    echo ""
    ;;
esac
