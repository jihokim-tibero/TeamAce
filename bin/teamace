#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────
# TeamAce CLI
# ─────────────────────────────────────────────

VERSION_FILE="$HOME/.claude/teamace/version"
TEAMACE_DIR="$HOME/.claude/teamace"
CLAUDE_DIR="$HOME/.claude"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[TeamAce]${NC} $1"; }
ok()    { echo -e "${GREEN}[TeamAce]${NC} $1"; }
warn()  { echo -e "${YELLOW}[TeamAce]${NC} $1"; }
err()   { echo -e "${RED}[TeamAce]${NC} $1" >&2; }

check_installed() {
  if [ ! -f "$VERSION_FILE" ]; then
    err "TeamAce가 설치되어 있지 않습니다. install.sh를 먼저 실행하세요."
    exit 1
  fi
}

# Git 플랫폼 감지
detect_platform() {
  local dir="$1"
  local origin_url
  origin_url=$(git -C "$dir" config --get remote.origin.url 2>/dev/null)

  # 1. URL 문자열로 판별
  if echo "$origin_url" | grep -q "github.com"; then
    echo "github"; return
  elif echo "$origin_url" | grep -qi "gitlab"; then
    echo "gitlab"; return
  elif echo "$origin_url" | grep -q "bitbucket"; then
    echo "bitbucket"; return
  fi

  # 2. .gitlab-ci.yml 존재
  if [ -f "$dir/.gitlab-ci.yml" ]; then
    echo "gitlab"; return
  fi

  # 3. remote 호스트의 GitLab API 확인 (자체 호스팅 대응)
  local host
  host=$(echo "$origin_url" | sed -E 's#^(https?://|git@)([^/:]+).*#\2#')
  if [ -n "$host" ]; then
    # http(s) 프로토콜 감지
    local scheme="https"
    echo "$origin_url" | grep -q "^http://" && scheme="http"
    if curl -s --max-time 3 -o /dev/null -w "%{http_code}" "${scheme}://${host}/api/v4/version" 2>/dev/null | grep -qE "^(200|401|403)$"; then
      echo "gitlab"; return
    fi
  fi

  echo "unknown"
}

# Agent Team 실험 기능 활성화 여부 확인
check_agent_team() {
  if [ -f "$CLAUDE_DIR/settings.json" ]; then
    node -e "
      const s = JSON.parse(require('fs').readFileSync('$CLAUDE_DIR/settings.json','utf8'));
      process.exit(s.env && s.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS === '1' ? 0 : 1);
    " 2>/dev/null && return 0
  fi
  # 환경변수로도 체크
  [ "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" = "1" ] && return 0
  return 1
}

# Impeccable 설치 여부 확인 (글로벌 + 프로젝트 레벨)
check_impeccable() {
  local project="${1:-.}"
  # 글로벌: ~/.agents/skills/ (npx skills add --global)
  ls "$HOME"/.agents/skills/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$HOME/.agents/skills/frontend-design" ] && return 0
  # 글로벌: ~/.claude/commands/ (Claude Code symlink)
  ls "$HOME"/.claude/commands/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$HOME/.claude/commands/frontend-design" ] && return 0
  # 프로젝트 레벨 (레거시)
  ls "$project"/.claude/skills/*impeccable* &>/dev/null 2>&1 && return 0
  [ -d "$project/.claude/skills/frontend-design" ] && return 0
  return 1
}

# ─────────────────────────────────────────────
# Toolchain 검사 — P0 도구 (TypeScript, ESLint, Husky+commitlint)
# ─────────────────────────────────────────────

# tsconfig.json 에서 strict: true 여부 확인
# $1 = 프로젝트 디렉터리
check_typescript_strict() {
  local dir="$1"
  local tsconfig="$dir/tsconfig.json"
  [ -f "$tsconfig" ] || return 2  # tsconfig 자체가 없음
  node -e "
    const ts = JSON.parse(require('fs').readFileSync('$tsconfig','utf8'));
    process.exit(ts.compilerOptions && ts.compilerOptions.strict === true ? 0 : 1);
  " 2>/dev/null && return 0
  return 1  # strict 가 false 이거나 없음
}

# ESLint 설정 파일 존재 + 핵심 규칙 확인
# 반환: 0=설정+핵심규칙 OK, 1=설정 파일 없음, 2=설정 있으나 핵심 규칙 부족
# $1 = 프로젝트 디렉터리
check_eslint_setup() {
  local dir="$1"
  local config_file=""

  # flat config or legacy config 찾기
  for f in "$dir"/eslint.config.{js,mjs,cjs,ts} "$dir"/.eslintrc{,.js,.cjs,.json,.yml,.yaml}; do
    [ -f "$f" ] && config_file="$f" && break
  done

  # package.json 내 eslintConfig 필드
  if [ -z "$config_file" ] && [ -f "$dir/package.json" ]; then
    node -e "
      const p = JSON.parse(require('fs').readFileSync('$dir/package.json','utf8'));
      process.exit(p.eslintConfig ? 0 : 1);
    " 2>/dev/null && config_file="$dir/package.json"
  fi

  [ -z "$config_file" ] && return 1  # 설정 파일 자체가 없음

  # 핵심 규칙 존재 여부 확인: 설정 파일 + node_modules 에서 키워드 검색
  # TeamAce P0 핵심 규칙: no-console, no-explicit-any
  local missing_rules=()
  if ! grep -rq "no-console" "$dir"/eslint.config.* "$dir"/.eslintrc* "$dir"/package.json 2>/dev/null; then
    missing_rules+=("no-console")
  fi
  if ! grep -rq "no-explicit-any\|@typescript-eslint" "$dir"/eslint.config.* "$dir"/.eslintrc* "$dir"/package.json 2>/dev/null; then
    missing_rules+=("@typescript-eslint/no-explicit-any")
  fi

  if [ ${#missing_rules[@]} -gt 0 ]; then
    # 글로벌 변수로 누락 규칙 전달
    ESLINT_MISSING_RULES="${missing_rules[*]}"
    return 2  # 설정 있으나 핵심 규칙 부족
  fi

  ESLINT_MISSING_RULES=""
  return 0
}

# Husky 설정 확인 — .husky/ 존재 + 훅 파일 내용 검사
# 반환: 0=훅 정상, 1=디렉터리 없음, 2=디렉터리 있으나 훅 부족
# $1 = 프로젝트 디렉터리
check_husky_setup() {
  local dir="$1"
  [ -d "$dir/.husky" ] || return 1

  local missing_hooks=()

  # commit-msg 훅 존재 + commitlint 연동 확인
  if [ -f "$dir/.husky/commit-msg" ]; then
    grep -q "commitlint" "$dir/.husky/commit-msg" 2>/dev/null || missing_hooks+=("commit-msg→commitlint")
  else
    missing_hooks+=("commit-msg")
  fi

  # pre-push 훅 존재 + main 브랜치 차단 확인
  if [ -f "$dir/.husky/pre-push" ]; then
    grep -q "main" "$dir/.husky/pre-push" 2>/dev/null || missing_hooks+=("pre-push→main차단")
  else
    missing_hooks+=("pre-push")
  fi

  if [ ${#missing_hooks[@]} -gt 0 ]; then
    HUSKY_MISSING_HOOKS="${missing_hooks[*]}"
    return 2
  fi

  HUSKY_MISSING_HOOKS=""
  return 0
}

# commitlint 설정 확인 — 설정 파일 존재 + extends 설정 여부
# 반환: 0=정상, 1=설정 없음, 2=설정 있으나 extends 미설정
# $1 = 프로젝트 디렉터리
check_commitlint_setup() {
  local dir="$1"
  local config_file=""

  for f in "$dir"/commitlint.config.{js,cjs,mjs,ts} "$dir"/.commitlintrc{,.js,.cjs,.json,.yml,.yaml}; do
    [ -f "$f" ] && config_file="$f" && break
  done

  # package.json 내 commitlint 필드
  if [ -z "$config_file" ] && [ -f "$dir/package.json" ]; then
    node -e "
      const p = JSON.parse(require('fs').readFileSync('$dir/package.json','utf8'));
      process.exit(p.commitlint ? 0 : 1);
    " 2>/dev/null && config_file="$dir/package.json"
  fi

  [ -z "$config_file" ] && return 1  # 설정 파일 자체가 없음

  # extends 설정 확인 (config-conventional 등)
  if ! grep -rq "extends\|config-conventional" "$config_file" 2>/dev/null; then
    return 2  # 설정 있으나 extends 미설정
  fi

  return 0
}

# 단일 디렉터리에 대한 Toolchain 검사 실행 + 안내 출력
# $1 = 프로젝트(또는 서브레포) 디렉터리, $2 = 라벨 (옵션)
run_toolchain_check() {
  local dir="$1"
  local label="${2:-}"
  local has_package_json=0
  [ -f "$dir/package.json" ] && has_package_json=1

  if [ "$has_package_json" -eq 0 ]; then
    return  # Node 프로젝트가 아니면 검사 스킵
  fi

  [ -n "$label" ] && info "─── ${label} 도구 검사 ───"

  local missing_items=()

  # 1) TypeScript strict
  local ts_result
  check_typescript_strict "$dir" && ts_result="ok" || ts_result=$?
  if [ "$ts_result" = "ok" ]; then
    ok "  → TypeScript strict: 활성화됨"
  elif [ "$ts_result" = "2" ]; then
    warn "  → TypeScript strict: tsconfig.json 없음"
    missing_items+=("typescript")
  else
    warn "  → TypeScript strict: 비활성 상태"
    missing_items+=("typescript-strict")
  fi

  # 2) ESLint
  local eslint_result
  ESLINT_MISSING_RULES=""
  check_eslint_setup "$dir" && eslint_result="ok" || eslint_result=$?
  if [ "$eslint_result" = "ok" ]; then
    ok "  → ESLint: 핵심 규칙 적용됨"
  elif [ "$eslint_result" = "2" ]; then
    warn "  → ESLint: 설정은 있으나 누락 규칙 — ${ESLINT_MISSING_RULES}"
    missing_items+=("eslint-rules")
  else
    warn "  → ESLint: 설정 파일 없음"
    missing_items+=("eslint")
  fi

  # 3) Husky
  local husky_result
  HUSKY_MISSING_HOOKS=""
  check_husky_setup "$dir" && husky_result="ok" || husky_result=$?
  if [ "$husky_result" = "ok" ]; then
    ok "  → Husky: 훅 정상 (commit-msg, pre-push)"
  elif [ "$husky_result" = "2" ]; then
    warn "  → Husky: 디렉터리 있으나 훅 부족 — ${HUSKY_MISSING_HOOKS}"
    missing_items+=("husky-hooks")
  else
    warn "  → Husky: 미설치"
    missing_items+=("husky")
  fi

  # 4) commitlint
  local commitlint_result
  check_commitlint_setup "$dir" && commitlint_result="ok" || commitlint_result=$?
  if [ "$commitlint_result" = "ok" ]; then
    ok "  → commitlint: 설정 정상"
  elif [ "$commitlint_result" = "2" ]; then
    warn "  → commitlint: 설정 파일은 있으나 extends 미설정"
    missing_items+=("commitlint-extends")
  else
    warn "  → commitlint: 설정 파일 없음"
    missing_items+=("commitlint")
  fi

  # 누락 항목이 있으면 설정 가이드 출력
  if [ ${#missing_items[@]} -gt 0 ]; then
    echo ""
    echo -e "  ${YELLOW}📋 설정 가이드${NC} (${dir##*/})"
    echo ""

    for item in "${missing_items[@]}"; do
      case "$item" in
        typescript)
          echo -e "  ${BOLD}[TypeScript]${NC} 설치 및 strict 모드 활성화:"
          echo "    npm install -D typescript"
          echo "    npx tsc --init  # 생성 후 strict: true 확인"
          echo ""
          ;;
        typescript-strict)
          echo -e "  ${BOLD}[TypeScript strict]${NC} tsconfig.json 수정:"
          echo "    compilerOptions.strict = true"
          echo "    compilerOptions.noImplicitAny = true"
          echo ""
          ;;
        eslint)
          echo -e "  ${BOLD}[ESLint]${NC} 설치 및 설정:"
          echo "    npm install -D eslint @typescript-eslint/eslint-plugin @typescript-eslint/parser"
          echo "    # eslint.config.mjs 를 생성하고 아래 규칙 추가:"
          echo "    #   no-console: error"
          echo "    #   max-lines: [warn, 300]"
          echo "    #   max-lines-per-function: [warn, { max: 50 }]"
          echo "    #   @typescript-eslint/no-explicit-any: error"
          echo "    #   camelcase: [error, { properties: always }]"
          echo "    #   no-magic-numbers: [warn, { ignore: [0, 1, -1] }]"
          echo ""
          ;;
        eslint-rules)
          echo -e "  ${BOLD}[ESLint 규칙 보완]${NC} 다음 규칙을 ESLint 설정에 추가하세요:"
          for rule in $ESLINT_MISSING_RULES; do
            echo "    - $rule"
          done
          echo "    # 권장 전체 규칙:"
          echo "    #   no-console: error"
          echo "    #   max-lines: [warn, 300]"
          echo "    #   max-lines-per-function: [warn, { max: 50 }]"
          echo "    #   @typescript-eslint/no-explicit-any: error"
          echo "    #   camelcase: [error, { properties: always }]"
          echo "    #   no-magic-numbers: [warn, { ignore: [0, 1, -1] }]"
          echo ""
          ;;
        husky)
          echo -e "  ${BOLD}[Husky]${NC} 설치:"
          echo "    npm install -D husky"
          echo "    npx husky init"
          echo "    # .husky/commit-msg 훅 생성 (commitlint 연동):"
          echo '    echo "npx --no -- commitlint --edit \$1" > .husky/commit-msg'
          echo "    # .husky/pre-push 훅 생성 (main 브랜치 푸시 차단):"
          echo '    cat > .husky/pre-push << '\''HOOK'\'''
          echo '    branch=$(git rev-parse --abbrev-ref HEAD)'
          echo '    if [ "$branch" = "main" ]; then echo "main 직접 push 금지"; exit 1; fi'
          echo '    HOOK'
          echo ""
          ;;
        husky-hooks)
          echo -e "  ${BOLD}[Husky 훅 보완]${NC} 누락된 훅을 추가하세요:"
          for hook in $HUSKY_MISSING_HOOKS; do
            case "$hook" in
              commit-msg*)
                echo "    # .husky/commit-msg 훅 생성:"
                echo '    echo "npx --no -- commitlint --edit \$1" > .husky/commit-msg'
                ;;
              pre-push*)
                echo "    # .husky/pre-push 훅 생성 (main 브랜치 푸시 차단):"
                echo '    cat > .husky/pre-push << '\''HOOK'\'''
                echo '    branch=$(git rev-parse --abbrev-ref HEAD)'
                echo '    if [ "$branch" = "main" ]; then echo "main 직접 push 금지"; exit 1; fi'
                echo '    HOOK'
                ;;
            esac
          done
          echo ""
          ;;
        commitlint)
          echo -e "  ${BOLD}[commitlint]${NC} 설치 및 설정:"
          echo "    npm install -D @commitlint/cli @commitlint/config-conventional"
          echo "    echo \"export default { extends: ['@commitlint/config-conventional'] };\" > commitlint.config.mjs"
          echo ""
          ;;
        commitlint-extends)
          echo -e "  ${BOLD}[commitlint extends]${NC} 설정 파일에 extends를 추가하세요:"
          echo "    export default { extends: ['@commitlint/config-conventional'] };"
          echo ""
          ;;
      esac
    done
  fi
}

# ─────────────────────────────────────────────
# teamace init — 현재 프로젝트 초기화
# ─────────────────────────────────────────────

cmd_init() {
  check_installed

  local project_dir="${1:-.}"
  project_dir="$(cd "$project_dir" && pwd)"

  info "프로젝트 초기화: $project_dir"
  echo ""

  # Detect project structure: single repo / multi-repo / no repo
  local project_type="none"
  local -a sub_repos=()
  local platforms=""

  if [ -d "$project_dir/.git" ]; then
    project_type="single"
    platforms=$(detect_platform "$project_dir")
    info "Git 저장소: 단일 레포"
    info "Git 플랫폼: $platforms"
  else
    # Scan for git repos in immediate subdirectories
    for d in "$project_dir"/*/; do
      [ -d "${d}.git" ] && sub_repos+=("$(basename "$d")")
    done

    if [ ${#sub_repos[@]} -gt 0 ]; then
      project_type="multi"
      info "멀티 레포 프로젝트 감지 (${#sub_repos[@]}개 레포)"
      for repo in "${sub_repos[@]}"; do
        local p
        p=$(detect_platform "$project_dir/$repo")
        echo -e "    ${CYAN}→${NC} $repo ${BOLD}($p)${NC}"
        # Collect unique platforms
        case "$platforms" in
          *"$p"*) ;;
          "") platforms="$p" ;;
          *)  platforms="$platforms, $p" ;;
        esac
      done
      info "Git 플랫폼: $platforms"
    else
      warn "Git 저장소가 아니며 하위 레포도 없습니다."
      read -rp "그래도 계속 진행하시겠습니까? [y/N] " yn
      [[ "$yn" =~ ^[Yy]$ ]] || exit 0
      platforms="unknown"
      info "Git 플랫폼: $platforms"
    fi
  fi

  # 1. Check Impeccable design skill (글로벌 설치 여부만 확인)
  info "Impeccable 디자인 스킬 확인 중..."
  if check_impeccable "$project_dir"; then
    ok "  → Impeccable 설치됨"
  else
    warn "  → Impeccable이 설치되어 있지 않습니다."
    warn "  → install.sh를 다시 실행하거나 수동으로 설치하세요:"
    warn "    npx skills add pbakaus/impeccable --agent claude-code --global --yes"
  fi

  # 2. Check Agent Team experimental feature
  info "Agent Team 실험 기능 확인 중..."
  if check_agent_team; then
    ok "  → Agent Team 활성화됨"
  else
    warn "  → Agent Team이 비활성 상태입니다."
    warn "  → install.sh를 다시 실행하거나, ~/.claude/settings.json에 다음을 추가하세요:"
    echo '    "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }'
  fi

  # 3. Create project-level knowledge directory
  info "프로젝트 Knowledge 디렉터리 생성 중..."
  local knowledge_dir="$project_dir/.claude/teamace/knowledge"
  mkdir -p "$knowledge_dir"

  for agent in pm pub fe be qa; do
    if [ ! -f "$knowledge_dir/$agent.md" ]; then
      {
        echo "# ${agent^^} Agent — Knowledge Base"
        echo ""
        echo "## 재사용 가능한 패턴"
        echo ""
        echo "## 실수와 회피 방법"
        echo ""
        echo "## 사용자 선호"
        echo ""
      } > "$knowledge_dir/$agent.md"
    fi
  done
  ok "  → .claude/teamace/knowledge/ 생성 완료 (에이전트 5개)"

  # 4. Toolchain 검사 (P0: TypeScript strict, ESLint, Husky+commitlint)
  info "코드 품질 도구 검사 중..."
  echo ""

  if [ "$project_type" = "multi" ]; then
    for repo in "${sub_repos[@]}"; do
      run_toolchain_check "$project_dir/$repo" "$repo"
    done
  else
    run_toolchain_check "$project_dir"
  fi

  # 5. Create project-level CLAUDE.md if not exists
  local project_claude="$project_dir/CLAUDE.md"
  if [ ! -f "$project_claude" ]; then
    info "프로젝트 CLAUDE.md 생성 중..."

    {
      echo "# 프로젝트 설정"
      echo ""
      echo "- **프로젝트명**: (기입)"
      echo "- **기술 스택**: (기입)"

      if [ "$project_type" = "multi" ]; then
        echo ""
        echo "## 레포지토리 구성"
        echo ""
        for repo in "${sub_repos[@]}"; do
          local p
          p=$(detect_platform "$project_dir/$repo")
          echo "- **$repo** ($p): (역할 기입)"
        done
      fi

      echo ""
      echo "## 프로젝트별 규칙"
      echo ""
    } > "$project_claude"

    ok "  → CLAUDE.md 생성 완료"
  else
    ok "  → CLAUDE.md 이미 존재 (건너뜀)"
  fi

  # 6. Summary
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN} 프로젝트 초기화 완료!${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo "  프로젝트: $project_dir"
  echo "  구조:     $([ "$project_type" = "multi" ] && echo "멀티 레포 (${#sub_repos[@]}개)" || echo "단일 레포")"
  echo "  플랫폼:   $platforms"
  if [ "$project_type" = "multi" ]; then
    echo "  레포:"
    for repo in "${sub_repos[@]}"; do
      echo "    → $repo"
    done
  fi
  echo ""
  echo "  이제 이 디렉터리에서 Claude Code를 실행하면 TeamAce를 사용할 수 있습니다."
  echo ""
}

# ─────────────────────────────────────────────
# teamace status — 설치 상태 확인
# ─────────────────────────────────────────────

cmd_status() {
  echo ""
  echo -e "${BOLD}TeamAce 설치 상태${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Version
  if [ -f "$VERSION_FILE" ]; then
    echo -e "  버전:          ${GREEN}$(cat "$VERSION_FILE")${NC}"
  else
    echo -e "  버전:          ${RED}미설치${NC}"
    return
  fi

  # Agents
  local agent_count
  agent_count=$(ls "$CLAUDE_DIR"/agents/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  에이전트:      ${GREEN}${agent_count}개${NC} (~/.claude/agents/)"

  # Skills
  local skill_count
  skill_count=$(find "$TEAMACE_DIR/skills" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  스킬:          ${GREEN}${skill_count}개${NC}"

  # Contracts
  local contract_count
  contract_count=$(ls "$TEAMACE_DIR"/contracts/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  계약:          ${GREEN}${contract_count}개${NC}"

  # CLAUDE.md
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -q "TEAMACE:START" "$CLAUDE_DIR/CLAUDE.md"; then
    echo -e "  글로벌 지침:   ${GREEN}적용됨${NC}"
  else
    echo -e "  글로벌 지침:   ${RED}미적용${NC}"
  fi

  # Agent Team
  if check_agent_team; then
    echo -e "  Agent Team:    ${GREEN}활성화${NC}"
  else
    echo -e "  Agent Team:    ${RED}비활성${NC} (install.sh 재실행 필요)"
  fi

  # Current project check
  echo ""
  echo -e "${BOLD}현재 프로젝트 ($(pwd))${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if [ -f "CLAUDE.md" ]; then
    echo -e "  CLAUDE.md:     ${GREEN}있음${NC}"
  else
    echo -e "  CLAUDE.md:     ${YELLOW}없음 (teamace init 실행 필요)${NC}"
  fi

  # Knowledge
  local knowledge_count=0
  if [ -d ".claude/teamace/knowledge" ]; then
    knowledge_count=$(ls .claude/teamace/knowledge/*.md 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  Knowledge:     ${GREEN}${knowledge_count}개${NC} (.claude/teamace/knowledge/)"
  else
    echo -e "  Knowledge:     ${YELLOW}없음 (teamace init 실행 필요)${NC}"
  fi

  if check_impeccable "$(pwd)"; then
    echo -e "  Impeccable:    ${GREEN}설치됨${NC}"
  else
    echo -e "  Impeccable:    ${YELLOW}미설치${NC}"
  fi

  # Detect project structure
  if [ -d ".git" ]; then
    local platform
    platform=$(detect_platform "$(pwd)")
    echo -e "  프로젝트 구조: 단일 레포"
    echo -e "  Git 플랫폼:    ${CYAN}${platform}${NC}"
  else
    local -a status_repos=()
    for d in ./*/; do
      [ -d "${d}.git" ] && status_repos+=("$(basename "$d")")
    done
    if [ ${#status_repos[@]} -gt 0 ]; then
      echo -e "  프로젝트 구조: ${CYAN}멀티 레포 (${#status_repos[@]}개)${NC}"
      for repo in "${status_repos[@]}"; do
        local p
        p=$(detect_platform "$(pwd)/$repo")
        echo -e "    ${CYAN}→${NC} $repo ($p)"
      done
    else
      echo -e "  프로젝트 구조: ${YELLOW}Git 저장소 없음${NC}"
    fi
  fi

  # Toolchain 상태
  echo ""
  echo -e "${BOLD}코드 품질 도구 (P0)${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  local current_dir
  current_dir="$(pwd)"

  if [ -d ".git" ]; then
    # 단일 레포
    run_toolchain_check "$current_dir"
  else
    local -a tc_repos=()
    for d in ./*/; do
      [ -f "${d}package.json" ] && tc_repos+=("$(basename "$d")")
    done
    if [ ${#tc_repos[@]} -gt 0 ]; then
      for repo in "${tc_repos[@]}"; do
        run_toolchain_check "$current_dir/$repo" "$repo"
      done
    else
      info "  Node 프로젝트를 찾을 수 없습니다."
    fi
  fi
  echo ""
}

# ─────────────────────────────────────────────
# teamace clean — 현재 프로젝트의 init 결과 정리
# ─────────────────────────────────────────────

cmd_clean() {
  local project_dir="${1:-.}"
  project_dir="$(cd "$project_dir" && pwd)"

  info "프로젝트 정리: $project_dir"
  echo ""

  local cleaned=0

  # 1. Remove project CLAUDE.md
  local project_claude="$project_dir/CLAUDE.md"
  if [ -f "$project_claude" ]; then
    warn "CLAUDE.md를 제거합니다."
    read -rp "CLAUDE.md를 삭제하시겠습니까? [y/N] " yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      rm -f "$project_claude"
      ok "  → CLAUDE.md 삭제 완료"
      cleaned=$((cleaned + 1))
    fi
  else
    info "  → CLAUDE.md 없음 (건너뜀)"
  fi

  # 2. Remove project-level knowledge
  if [ -d "$project_dir/.claude/teamace" ]; then
    warn "프로젝트 Knowledge (.claude/teamace/) 를 제거합니다."
    warn "  ⚠ 축적된 학습 기록이 삭제됩니다!"
    read -rp "제거하시겠습니까? [y/N] " yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      rm -rf "$project_dir/.claude/teamace"
      ok "  → .claude/teamace/ 제거 완료"
      cleaned=$((cleaned + 1))
    fi
  fi

  # 3. Remove Impeccable skills from project (레거시 프로젝트 레벨)
  if [ -d "$project_dir/.claude/skills" ]; then
    local has_impeccable=0
    [ -d "$project_dir/.claude/skills/frontend-design" ] && has_impeccable=1
    ls "$project_dir"/.claude/skills/*impeccable* &>/dev/null 2>&1 && has_impeccable=1

    if [ "$has_impeccable" -eq 1 ]; then
      warn "프로젝트 레벨 Impeccable 스킬을 제거합니다. (글로벌로 이관됨)"
      read -rp "제거하시겠습니까? [y/N] " yn
      if [[ "$yn" =~ ^[Yy]$ ]]; then
        rm -rf "$project_dir/.claude/skills"
        ok "  → .claude/skills/ 제거 완료"
        cleaned=$((cleaned + 1))
      fi
    fi
  fi

  # 4. Remove .claude directory if empty
  if [ -d "$project_dir/.claude" ]; then
    if [ -z "$(ls -A "$project_dir/.claude" 2>/dev/null)" ]; then
      rmdir "$project_dir/.claude"
      ok "  → 빈 .claude/ 디렉터리 제거 완료"
    fi
  fi

  echo ""
  if [ "$cleaned" -gt 0 ]; then
    ok "프로젝트 정리 완료 ($cleaned개 항목 제거)"
  else
    info "정리할 항목이 없습니다."
  fi
  echo ""
}

# ─────────────────────────────────────────────
# teamace update — TeamAce 업데이트
# ─────────────────────────────────────────────

cmd_update() {
  check_installed

  local current_version
  current_version=$(cat "$VERSION_FILE")
  info "현재 버전: $current_version"
  info "TeamAce 리포지토리에서 최신 버전을 pull한 후 install.sh를 다시 실행하세요."
  echo ""
  echo "  cd <TeamAce-repo-directory>"
  echo "  git pull"
  echo "  ./install.sh"
  echo ""
}

# ─────────────────────────────────────────────
# teamace uninstall — TeamAce 제거
# ─────────────────────────────────────────────

cmd_uninstall() {
  check_installed

  warn "TeamAce를 완전히 제거합니다."
  read -rp "정말 제거하시겠습니까? [y/N] " yn
  [[ "$yn" =~ ^[Yy]$ ]] || exit 0

  # Remove agents
  for agent in lead pm pub fe be qa; do
    rm -f "$CLAUDE_DIR/agents/$agent.md"
  done
  info "에이전트 정의 제거 완료"

  # Remove teamace directory
  rm -rf "$TEAMACE_DIR"
  info "TeamAce 지원 파일 제거 완료"

  # Remove CLAUDE.md section
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ]; then
    sed '/<!-- TEAMACE:START -->/,/<!-- TEAMACE:END -->/d' "$CLAUDE_DIR/CLAUDE.md" > "$CLAUDE_DIR/CLAUDE.md.tmp"
    mv "$CLAUDE_DIR/CLAUDE.md.tmp" "$CLAUDE_DIR/CLAUDE.md"
    # Remove file if empty
    if [ ! -s "$CLAUDE_DIR/CLAUDE.md" ]; then
      rm -f "$CLAUDE_DIR/CLAUDE.md"
    fi
    info "CLAUDE.md에서 TeamAce 지침 제거 완료"
  fi

  # Remove Agent Team env from settings.json
  if [ -f "$CLAUDE_DIR/settings.json" ]; then
    node -e "
      const fs = require('fs');
      const s = JSON.parse(fs.readFileSync('$CLAUDE_DIR/settings.json', 'utf8'));
      if (s.env) {
        delete s.env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS;
        if (Object.keys(s.env).length === 0) delete s.env;
      }
      fs.writeFileSync('$CLAUDE_DIR/settings.json', JSON.stringify(s, null, 2));
    " 2>/dev/null
    info "settings.json에서 Agent Team 설정 제거 완료"
  fi

  # Remove Impeccable global skill
  local impeccable_removed=0
  [ -d "$HOME/.agents/skills/frontend-design" ] && rm -rf "$HOME/.agents/skills/frontend-design" && impeccable_removed=1
  [ -d "$HOME/.claude/commands/frontend-design" ] && rm -rf "$HOME/.claude/commands/frontend-design" && impeccable_removed=1
  for f in "$HOME"/.claude/commands/*impeccable*; do
    [ -e "$f" ] && rm -rf "$f" && impeccable_removed=1
  done
  if [ "$impeccable_removed" -eq 1 ]; then
    info "Impeccable 글로벌 스킬 제거 완료"
  else
    info "Impeccable 글로벌 스킬 없음 (건너뜀)"
  fi

  # Remove CLI
  rm -f "$HOME/.local/bin/teamace"
  info "CLI 제거 완료"

  echo ""
  ok "TeamAce가 완전히 제거되었습니다."
  echo ""
  echo "  참고: 각 프로젝트의 CLAUDE.md에서 TeamAce 참조는 수동으로 제거해주세요."
  echo "        → 'teamace clean' 을 각 프로젝트에서 실행하면 자동 정리됩니다."
  echo ""
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

case "${1:-help}" in
  init)       cmd_init "${2:-}" ;;
  clean)      cmd_clean "${2:-}" ;;
  status)     cmd_status ;;
  update)     cmd_update ;;
  uninstall)  cmd_uninstall ;;
  -v|version) [ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "미설치" ;;
  help|*)
    echo ""
    echo -e "${BOLD}TeamAce${NC} — Multi-Agent Service Development System"
    echo ""
    echo "사용법:"
    echo "  teamace init [path]   현재 프로젝트(또는 지정 경로)에 TeamAce 초기화"
    echo "  teamace clean [path]  현재 프로젝트의 init 결과 정리 (CLAUDE.md, knowledge)"
    echo "  teamace status        설치 상태 및 현재 프로젝트 상태 확인"
    echo "  teamace update        업데이트 안내"
    echo "  teamace uninstall     TeamAce 글로벌 제거 (uninstall.sh와 동일)"
    echo "  teamace version       설치된 버전 출력"
    echo "  teamace help          이 도움말 표시"
    echo ""
    ;;
esac
