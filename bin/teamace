#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────
# TeamAce CLI
# ─────────────────────────────────────────────

VERSION_FILE="$HOME/.claude/teamace/version"
TEAMACE_DIR="$HOME/.claude/teamace"
CLAUDE_DIR="$HOME/.claude"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[TeamAce]${NC} $1"; }
ok()    { echo -e "${GREEN}[TeamAce]${NC} $1"; }
warn()  { echo -e "${YELLOW}[TeamAce]${NC} $1"; }
err()   { echo -e "${RED}[TeamAce]${NC} $1" >&2; }

check_installed() {
  if [ ! -f "$VERSION_FILE" ]; then
    err "TeamAce가 설치되어 있지 않습니다. install.sh를 먼저 실행하세요."
    exit 1
  fi
}

# ─────────────────────────────────────────────
# teamace init — 현재 프로젝트 초기화
# ─────────────────────────────────────────────

cmd_init() {
  check_installed

  local project_dir="${1:-.}"
  project_dir="$(cd "$project_dir" && pwd)"

  info "프로젝트 초기화: $project_dir"
  echo ""

  # Check if it's a git repo
  if [ ! -d "$project_dir/.git" ]; then
    warn "Git 저장소가 아닙니다. git init을 먼저 실행해주세요."
    read -rp "그래도 계속 진행하시겠습니까? [y/N] " yn
    [[ "$yn" =~ ^[Yy]$ ]] || exit 0
  fi

  # Detect git platform
  local platform="unknown"
  if git -C "$project_dir" remote -v 2>/dev/null | grep -q "github.com"; then
    platform="github"
  elif git -C "$project_dir" remote -v 2>/dev/null | grep -q "gitlab"; then
    platform="gitlab"
  fi
  info "Git 플랫폼: $platform"

  # 1. Install Impeccable design skill
  info "Impeccable 디자인 스킬 설치 중..."
  if [ -d "$project_dir/.claude/skills/frontend-design" ] || \
     ls "$project_dir"/.claude/skills/*impeccable* &>/dev/null 2>&1; then
    ok "  → Impeccable 이미 설치됨 (건너뜀)"
  else
    (cd "$project_dir" && npx -y skills add pbakaus/impeccable 2>/dev/null) && \
      ok "  → Impeccable 설치 완료" || \
      warn "  → Impeccable 자동 설치 실패. 수동 설치 필요: cd $project_dir && npx skills add pbakaus/impeccable"
  fi

  # 2. Create project-level CLAUDE.md if not exists
  local project_claude="$project_dir/CLAUDE.md"
  if [ ! -f "$project_claude" ]; then
    info "프로젝트 CLAUDE.md 생성 중..."
    cat > "$project_claude" << 'CLAUDEMD'
# 프로젝트 설정

## TeamAce 활성화

이 프로젝트는 TeamAce 멀티에이전트 시스템을 사용합니다.
작업 시작 전 반드시 `~/.claude/agents/lead.md`를 읽고 오케스트레이션 지침을 따르세요.

## 프로젝트 정보

- **프로젝트명**: (프로젝트명 기입)
- **Git 플랫폼**: (자동 감지됨)
- **기술 스택**: (기술 스택 기입)

## 프로젝트별 규칙

(프로젝트 고유 규칙을 여기에 추가하세요)
CLAUDEMD
    ok "  → CLAUDE.md 생성 완료"
  else
    # Check if TeamAce reference exists
    if ! grep -q "TeamAce" "$project_claude"; then
      warn "  → CLAUDE.md에 TeamAce 참조가 없습니다."
      warn "  → 다음 내용을 CLAUDE.md에 추가하세요:"
      echo ""
      echo "    ## TeamAce 활성화"
      echo "    이 프로젝트는 TeamAce 멀티에이전트 시스템을 사용합니다."
      echo "    작업 시작 전 반드시 \`~/.claude/agents/lead.md\`를 읽고 오케스트레이션 지침을 따르세요."
      echo ""
    else
      ok "  → CLAUDE.md에 TeamAce 참조 확인 완료"
    fi
  fi

  # 3. Create .claude directory structure
  mkdir -p "$project_dir/.claude"

  # 4. Summary
  echo ""
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${GREEN} 프로젝트 초기화 완료!${NC}"
  echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo "  프로젝트: $project_dir"
  echo "  플랫폼:   $platform"
  echo ""
  echo "  이제 이 디렉터리에서 Claude Code를 실행하면 TeamAce를 사용할 수 있습니다."
  echo ""
}

# ─────────────────────────────────────────────
# teamace status — 설치 상태 확인
# ─────────────────────────────────────────────

cmd_status() {
  echo ""
  echo -e "${BOLD}TeamAce 설치 상태${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Version
  if [ -f "$VERSION_FILE" ]; then
    echo -e "  버전:          ${GREEN}$(cat "$VERSION_FILE")${NC}"
  else
    echo -e "  버전:          ${RED}미설치${NC}"
    return
  fi

  # Agents
  local agent_count
  agent_count=$(ls "$CLAUDE_DIR"/agents/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  에이전트:      ${GREEN}${agent_count}개${NC} (~/.claude/agents/)"

  # Skills
  local skill_count
  skill_count=$(find "$TEAMACE_DIR/skills" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  스킬:          ${GREEN}${skill_count}개${NC}"

  # Contracts
  local contract_count
  contract_count=$(ls "$TEAMACE_DIR"/contracts/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  계약:          ${GREEN}${contract_count}개${NC}"

  # CLAUDE.md
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -q "TEAMACE:START" "$CLAUDE_DIR/CLAUDE.md"; then
    echo -e "  글로벌 지침:   ${GREEN}적용됨${NC}"
  else
    echo -e "  글로벌 지침:   ${RED}미적용${NC}"
  fi

  # Current project check
  echo ""
  echo -e "${BOLD}현재 프로젝트 ($(pwd))${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if [ -f "CLAUDE.md" ] && grep -q "TeamAce" "CLAUDE.md"; then
    echo -e "  TeamAce 참조:  ${GREEN}있음${NC}"
  else
    echo -e "  TeamAce 참조:  ${YELLOW}없음 (teamace init 실행 필요)${NC}"
  fi

  if [ -d ".claude/skills" ]; then
    if ls .claude/skills/*impeccable* &>/dev/null 2>&1 || [ -d ".claude/skills/frontend-design" ]; then
      echo -e "  Impeccable:    ${GREEN}설치됨${NC}"
    else
      echo -e "  Impeccable:    ${YELLOW}미설치${NC}"
    fi
  else
    echo -e "  Impeccable:    ${YELLOW}미설치${NC}"
  fi

  local platform="unknown"
  if git remote -v 2>/dev/null | grep -q "github.com"; then
    platform="GitHub"
  elif git remote -v 2>/dev/null | grep -q "gitlab"; then
    platform="GitLab"
  fi
  echo -e "  Git 플랫폼:    ${CYAN}${platform}${NC}"
  echo ""
}

# ─────────────────────────────────────────────
# teamace update — TeamAce 업데이트
# ─────────────────────────────────────────────

cmd_update() {
  check_installed

  local current_version
  current_version=$(cat "$VERSION_FILE")
  info "현재 버전: $current_version"
  info "TeamAce 리포지토리에서 최신 버전을 pull한 후 install.sh를 다시 실행하세요."
  echo ""
  echo "  cd <TeamAce-repo-directory>"
  echo "  git pull"
  echo "  ./install.sh"
  echo ""
}

# ─────────────────────────────────────────────
# teamace uninstall — TeamAce 제거
# ─────────────────────────────────────────────

cmd_uninstall() {
  check_installed

  warn "TeamAce를 완전히 제거합니다."
  read -rp "정말 제거하시겠습니까? [y/N] " yn
  [[ "$yn" =~ ^[Yy]$ ]] || exit 0

  # Remove agents
  for agent in lead pm pub fe be qa; do
    rm -f "$CLAUDE_DIR/agents/$agent.md"
  done
  info "에이전트 정의 제거 완료"

  # Remove teamace directory
  rm -rf "$TEAMACE_DIR"
  info "TeamAce 지원 파일 제거 완료"

  # Remove CLAUDE.md section
  if [ -f "$CLAUDE_DIR/CLAUDE.md" ]; then
    sed '/<!-- TEAMACE:START -->/,/<!-- TEAMACE:END -->/d' "$CLAUDE_DIR/CLAUDE.md" > "$CLAUDE_DIR/CLAUDE.md.tmp"
    mv "$CLAUDE_DIR/CLAUDE.md.tmp" "$CLAUDE_DIR/CLAUDE.md"
    # Remove file if empty
    if [ ! -s "$CLAUDE_DIR/CLAUDE.md" ]; then
      rm -f "$CLAUDE_DIR/CLAUDE.md"
    fi
    info "CLAUDE.md에서 TeamAce 지침 제거 완료"
  fi

  # Remove CLI
  rm -f "$HOME/.local/bin/teamace"
  info "CLI 제거 완료"

  echo ""
  ok "TeamAce가 완전히 제거되었습니다."
  echo ""
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────

case "${1:-help}" in
  init)       cmd_init "${2:-}" ;;
  status)     cmd_status ;;
  update)     cmd_update ;;
  uninstall)  cmd_uninstall ;;
  -v|version) [ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "미설치" ;;
  help|*)
    echo ""
    echo -e "${BOLD}TeamAce${NC} — Multi-Agent Service Development System"
    echo ""
    echo "사용법:"
    echo "  teamace init [path]   현재 프로젝트(또는 지정 경로)에 TeamAce 초기화"
    echo "  teamace status        설치 상태 및 현재 프로젝트 상태 확인"
    echo "  teamace update        업데이트 안내"
    echo "  teamace uninstall     TeamAce 완전 제거"
    echo "  teamace version       설치된 버전 출력"
    echo "  teamace help          이 도움말 표시"
    echo ""
    ;;
esac
